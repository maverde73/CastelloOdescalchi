<my:BaseDetailPage
	x:Class="Presentation.wndVisitRefund"
	xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
	xmlns:telerik2="clr-namespace:Telerik.Windows.Controls;assembly=Telerik.Windows.Controls" 
	xmlns:telerikGrid="clr-namespace:Telerik.Windows.Controls;assembly=Telerik.Windows.Controls.GridView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:my="clr-namespace:Presentation"
	xmlns:local="clr-namespace:Presentation"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
	xmlns:ntb="clr-namespace:NumericTextBox;assembly=NumericTextBox"
    mc:Ignorable="d" 
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
	xmlns:ent="clr-namespace:Scv_Entities;assembly=Scv_Entities"
    Title="Rmborso biglietti" 
	Height="290" 
	Width="700"
	Icon="../Themes/Images/icons/logo_us_16x16.png"	
	ResizeMode="NoResize" 
	WindowStartupLocation="CenterScreen"
	>	
	<Window.CommandBindings>
		<CommandBinding Command="New" CanExecute="Confirm_CanExecute" Executed="Confirm_Executed" />
	</Window.CommandBindings>

	<Window.Resources>
		<CollectionViewSource x:Key="cvsMovement" d:DesignSource="{d:DesignInstance ent:Movimento, CreateList=True}" />
		<CollectionViewSource x:Key="cvsMovementDetails" d:DesignSource="{d:DesignInstance ent:Movimento, CreateList=True}" />
		<CollectionViewSource x:Key="cvsProgressives" d:DesignSource="{d:DesignInstance ent:LK_Progressivi, CreateList=True}" />
		<CollectionViewSource x:Key="cvsAvailableWares" d:DesignSource="{d:DesignInstance ent:Articolo, CreateList=True}" />
	</Window.Resources>

	<Grid Name="grdPrenotationDetail">
		<Grid.RowDefinitions>
			<RowDefinition Height="40"></RowDefinition>
			<RowDefinition Height="Auto"></RowDefinition>
			<RowDefinition Height="5"></RowDefinition>
			<RowDefinition Height="Auto"></RowDefinition>
		</Grid.RowDefinitions>
		
		<Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="0.1" Margin="5">
			<Label Name="visitInfo" Content="{Binding VisitInfo}"></Label>
		</Border>

		<Border Name="brdPetitioner" Grid.Row="1" BorderBrush="Blue" BorderThickness="1" Background="#f1f1f1">
			<Grid Margin="10" >
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
				</Grid.RowDefinitions>

				<Grid Grid.Row="0" Margin="3">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="20*"></ColumnDefinition>
						<ColumnDefinition Width="40*"></ColumnDefinition>
						<ColumnDefinition Width="40*"></ColumnDefinition>
					</Grid.ColumnDefinitions>
					<DockPanel  HorizontalAlignment="Stretch" Grid.Column="0"></DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="1"></DockPanel>
					<DockPanel Name="pnlPaymentType" HorizontalAlignment="Stretch" Grid.Column="2"></DockPanel>
				</Grid>
				<Grid Name="grdRefund" Grid.Row="1" Margin="3">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="80*"></ColumnDefinition>
						<ColumnDefinition Width="20*"></ColumnDefinition>
					</Grid.ColumnDefinitions>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="0">
						<Label Content="Nominativo" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox 
							Name="txtNominativo"                             
							Text="{
                                Binding NominativoRimborso, 
                                Mode=TwoWay, 
                            	UpdateSourceTrigger=PropertyChanged
                            }" 
							MaxLength="100" 
							Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch"
							/>
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="1" >
						<Label Content="Importo" Grid.Column="9" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<ntb:NumericTextBox Name="txtRimborso" Text="{Binding ObjMovement.PrezzoVendita, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}" Validation.Error="Validation_Error" MaxLength="20" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
					</DockPanel>
				</Grid>
				<Grid Name="grdNote" Grid.Row="2" Margin="3">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="100*"></ColumnDefinition>
					</Grid.ColumnDefinitions>
					<StackPanel>
						<Label Content="Autorizzazione / Nota" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" />
						<TextBox 
							Name="txtNota"                             
							Text="{
                                Binding ObjMovement.Nota, 
                                Mode=TwoWay, 
                                ValidatesOnDataErrors=True, 
                                NotifyOnValidationError=True,
                            	UpdateSourceTrigger=PropertyChanged
                            }" 
                            Validation.Error="Validation_Error"	                            
							MaxLength="100" 
							Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch"
							/>
					</StackPanel>
				</Grid>
				<Grid Grid.Row="3" Margin="3">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="33*"></ColumnDefinition>
						<ColumnDefinition Width="33*"></ColumnDefinition>
						<ColumnDefinition Width="33*"></ColumnDefinition>
						<ColumnDefinition></ColumnDefinition>
					</Grid.ColumnDefinitions>
					<StackPanel Grid.Column="0" Margin="2">
						<Label Content="Data rimborso" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" />
						<Label Content="{Binding ObjMovement.Dt_Movimento}" Style="{StaticResource DataLabel}" HorizontalAlignment="Stretch" />
					</StackPanel>
					<StackPanel Grid.Column="1" Margin="2">
						<Label Content="Protocollo" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" />
						<Label Content="{Binding ObjPrenotationProtocol}" Style="{StaticResource DataLabel}" HorizontalAlignment="Stretch" />
					</StackPanel>
					<StackPanel Grid.Column="2" Margin="2">
						<Label Content="Ricevuta pagamento" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" />
						<Label Content="{Binding ObjVisitReceipt}" Style="{StaticResource DataLabel}" HorizontalAlignment="Stretch" />
					</StackPanel>
				</Grid>
			</Grid>
		</Border>

		<Border Name="brdButtons" Grid.Row="3" BorderBrush="Blue" BorderThickness="1" Background="#f1f1f1">
			<Grid x:Name="grdButtons" Margin="3" >
				<StackPanel Orientation="Horizontal">
					<telerik:RadButton Name="btnSave" Content="Salva" Width="100" Height="25" />
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</my:BaseDetailPage>