<my:BaseParamWindow
    x:Class="Presentation.wndYearMonth"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
	xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    mc:Ignorable="d" 
    ResizeMode="NoResize"
    Width="270"
    Height="190"
	xmlns:my="clr-namespace:Presentation"
	xmlns:sysglb="clr-namespace:System.Globalization;assembly=mscorlib"	
	Title="Scelta anno e mese" 
	WindowStartupLocation="CenterScreen"
    
    >
	<Grid Margin="10">
		<StackPanel>
			<StackPanel Orientation="Horizontal">
				<StackPanel Margin="5">
					<Label Content="Anno" Style="{StaticResource CaptionLabel}" />
					<telerik:RadComboBox 						
							Name="cmbYear" 
							Width="100"
							Style="{StaticResource ValidationRadComboBox}"
							ItemsSource="{Binding Years}"
							SelectedValue="{Binding SelectedYear.Number, Mode=TwoWay}"
							DisplayMemberPath="Description"
							SelectedValuePath="Number"
							/>
				</StackPanel>
				<StackPanel Margin="5">
					<Label Content="Mese" Style="{StaticResource CaptionLabel}" />
					<telerik:RadComboBox 
							Name="cmbMonth" 
							Width="100"
							Style="{StaticResource ValidationRadComboBox}" 
							ItemsSource="{Binding Months}"
							SelectedValue="{Binding SelectedMonth.Number, Mode=TwoWay}"						
							DisplayMemberPath="Description"
							SelectedValuePath="Number"						
							/>
				</StackPanel>
			</StackPanel>
			<StackPanel Name="pnlStore" Orientation="Horizontal">
				<StackPanel Margin="5">
					<Label Content="Esercizio di vendita" Style="{StaticResource CaptionLabel}" />
					<telerik:RadComboBox 						
						Name="cmbStore"
						Width="210"
						Style="{StaticResource ValidationRadComboBox}"
						ItemsSource="{Binding Stores}"
						SelectedValue="{Binding SelectedStoreID, Mode=TwoWay}"
						DisplayMemberPath="Descrizione"
						SelectedValuePath="Id_EsercizioVendita"
							/>
				</StackPanel>
			</StackPanel>
			<StackPanel Margin="5" VerticalAlignment="Stretch">
				<telerik:RadButton Name="btnOK" Content="OK" Width="100" HorizontalAlignment="Left" />
			</StackPanel>
		</StackPanel>
	</Grid>
</my:BaseParamWindow>
