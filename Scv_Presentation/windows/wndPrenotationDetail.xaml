<my:BaseDetailPage 
	x:Class="Presentation.wndPrenotationDetail"
	xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
	xmlns:telerik2="clr-namespace:Telerik.Windows.Controls;assembly=Telerik.Windows.Controls" 
	xmlns:telerikGrid="clr-namespace:Telerik.Windows.Controls;assembly=Telerik.Windows.Controls.GridView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:my="clr-namespace:Presentation"
	xmlns:local="clr-namespace:Presentation"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
	xmlns:sysglb="clr-namespace:System.Globalization;assembly=mscorlib"			    	
    mc:Ignorable="d" 
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
	xmlns:ent="clr-namespace:Scv_Entities;assembly=Scv_Entities"
    Title="Prenotazione" 
	Height="670" 
	MinHeight="670"
	Width="1070"
	Icon="../Themes/Images/icons/logo_us_16x16.png"	
        
	>
	<Window.CommandBindings>
		<CommandBinding Command="New" CanExecute="Confirm_CanExecute" Executed="Confirm_Executed" />
	</Window.CommandBindings>

	<Window.Resources>
		<SolidColorBrush x:Key="Black" Color="#FF000000"/>
		<SolidColorBrush x:Key="Grey" Color="#FF767676"/>
		<SolidColorBrush x:Key="W Grey" Color="#FFD6D4D4"/>
		<Style x:Key="AutoCompleteStyle" TargetType="TextBlock">
			<Setter Property="FontFamily" Value="Segoe UI" />
			<Setter Property="FontSize" Value="13.333" />
			<Setter Property="Foreground" Value="#FF0A0A0A" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>

		<DataTemplate x:Name="tmpPetitioner" x:Key="aucPetitioner">
			<StackPanel Orientation="Horizontal">
				<TextBlock Text="{Binding Cognome}" Style="{StaticResource AutoCompleteStyle}" />
				<TextBlock Text=", " Style="{StaticResource AutoCompleteStyle}" />
				<TextBlock Text="{Binding Nome}" Style="{StaticResource AutoCompleteStyle}" />
			</StackPanel>
		</DataTemplate>

	</Window.Resources>

	<Grid Name="grdPrenotationDetail">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"></RowDefinition>
			<RowDefinition Height="5"></RowDefinition>
			<RowDefinition Height="Auto"></RowDefinition>
			<RowDefinition Height="5"></RowDefinition>
			<RowDefinition></RowDefinition>
			<RowDefinition Height="5"></RowDefinition>
			<RowDefinition Height="Auto"></RowDefinition>
		</Grid.RowDefinitions>

		<Border Name="brdPetitioner" Grid.Row="0" BorderBrush="Blue" BorderThickness="1" Background="#f1f1f1">
			<Grid x:Name="grdPetitioner" Margin="10" >
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
				</Grid.RowDefinitions>

				<!-- Ricerca richiedente -->
				<Grid Grid.Row="0" Margin="3">
					<DockPanel Margin="0" HorizontalAlignment="Stretch">
						<Label Name="lblSearch" Content="Cerca Richiedente" Style="{StaticResource CaptionLabel}" DockPanel.Dock="Top" HorizontalAlignment="Stretch" />
						<telerik:RadAutoCompleteBox 
							Name="cmbPetitioner"
							HorizontalAlignment="Stretch"
							MinWidth="300"
							SelectionMode="Single"
							TextSearchMode="StartsWith"
							TextSearchPath="Cognome"
							DisplayMemberPath="Cognome"
							WatermarkContent="Richiedente..."
							DropDownItemTemplate="{StaticResource aucPetitioner}"	
							AutoCompleteMode="Suggest"							
							ItemsSource="{Binding AvailablePetitioners}"
							/>
						<StackPanel Margin="20,0,0,0">
							<CheckBox Name="chkNewPetitioner" Content="Nuovo richiedente" IsTabStop="False" />
						</StackPanel>
					</DockPanel>
				</Grid>
				<!-- Campi richiedente-->
				<Grid Grid.Row="1" Margin="3">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="30*"></ColumnDefinition>
						<ColumnDefinition Width="30*"></ColumnDefinition>
						<ColumnDefinition Width="20*"></ColumnDefinition>
                        <ColumnDefinition Width="3*"></ColumnDefinition>
                        <ColumnDefinition Width="5*"></ColumnDefinition>
					</Grid.ColumnDefinitions>
					<DockPanel Grid.Column="0" HorizontalAlignment="Stretch" KeyboardNavigation.TabNavigation="None">
						<Label Content="Cognome o Ragione Sociale" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtCognome" Validation.Error="Validation_Error" MaxLength="50" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" TextChanged="PetitionerChanghed">
							<Binding
								Path="ObjPetitioner.Cognome"
							    Mode="TwoWay"
								ValidatesOnDataErrors="True"
								NotifyOnValidationError="True"
								UpdateSourceTrigger="PropertyChanged"
								/>
						</TextBox>
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="1">
						<Label Content="Nome" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtNome" Validation.Error="Validation_Error" MaxLength="50" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" TextChanged="PetitionerChanghed">
							<Binding
								Path="ObjPetitioner.Nome"
							    Mode="TwoWay"
								ValidatesOnDataErrors="True"
								NotifyOnValidationError="True"
								UpdateSourceTrigger="PropertyChanged"
								/>
						</TextBox>
					</DockPanel>
					<DockPanel Grid.Column="2" HorizontalAlignment="Stretch" >
                        <Label Name="lblPIVACF" Content="C.F./P.IVA" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
                        <TextBox Name="txtPIVACF" Validation.Error="Validation_Error" MaxLength="50" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" TextChanged="PetitionerChanghed">
                            <Binding
								Path="ObjPetitioner.CF_PIVA"
							    Mode="TwoWay"
								ValidatesOnDataErrors="True"
								NotifyOnValidationError="True"
								UpdateSourceTrigger="PropertyChanged"
								/>
                        </TextBox>
                    </DockPanel>
                    <DockPanel Grid.Column="3" HorizontalAlignment="Center" >
                        <Label Name="lblPF" Content="PF" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
                        <CheckBox Name="chkPF" IsThreeState="False" IsChecked="{Binding ObjPetitioner.Is_PF, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}" VerticalAlignment="Top" HorizontalAlignment="Center" Checked="chkPF_Checked" Unchecked="chkPF_Unchecked" />
                    </DockPanel>
                    <DockPanel Grid.Column="4" HorizontalAlignment="Left" >
                        <Label Name="lblSesso" Content="Sesso" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
                        <telerik:RadComboBox 
							Name="cmbSesso"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch" SelectedValuePath="Content">
						    
                            <telerik:RadComboBoxItem Content="M" IsSelected="True"/>
                            <telerik:RadComboBoxItem Content="F"/>
                        </telerik:RadComboBox>
							
                    </DockPanel>
                </Grid>
				<Grid Grid.Row="2" Margin="3">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="30*"></ColumnDefinition>
						<ColumnDefinition Width="20*"></ColumnDefinition>
						<ColumnDefinition Width="20*"></ColumnDefinition>
						<ColumnDefinition Width="20*"></ColumnDefinition>
						<ColumnDefinition Width="20*"></ColumnDefinition>
					</Grid.ColumnDefinitions>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="0" >
						<Label Content="Email" Grid.Column="9" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtEmail"  TextChanged="PetitionerChanghed" Validation.Error="Validation_Error" MaxLength="50" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch">
							<Binding
								Path="ObjPetitioner.Email"
							    Mode="TwoWay"
								ValidatesOnDataErrors="True"
								NotifyOnValidationError="True"
								UpdateSourceTrigger="PropertyChanged"
								/>
						</TextBox>
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="1">
						<Label Content="Tel. Ufficio/Fax" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtTelUfficio"  TextChanged="PetitionerChanghed" Validation.Error="Validation_Error" MaxLength="20" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch">
							<Binding
								Path="ObjPetitioner.Tel_Ufficio"
							    Mode="TwoWay"
								ValidatesOnDataErrors="True"
								NotifyOnValidationError="True"
								UpdateSourceTrigger="PropertyChanged"
								/>
						</TextBox>
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="2" KeyboardNavigation.TabNavigation="None">
						<Label Content="Tel. Casa" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtTelefonoCasa"  TextChanged="PetitionerChanghed" Validation.Error="Validation_Error" MaxLength="20" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch">
							<Binding
								Path="ObjPetitioner.Tel_Casa"
							    Mode="TwoWay"
								ValidatesOnDataErrors="True"
								NotifyOnValidationError="True"
								UpdateSourceTrigger="PropertyChanged"
								/>
						</TextBox>
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="3" KeyboardNavigation.TabNavigation="None">
						<Label Content="Tel. Cell." Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtTelCellulare"  TextChanged="PetitionerChanghed" Validation.Error="Validation_Error" MaxLength="20" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch">
							<Binding
								Path="ObjPetitioner.Tel_Cellulare"
							    Mode="TwoWay"
								ValidatesOnDataErrors="True"
								NotifyOnValidationError="True"
								UpdateSourceTrigger="PropertyChanged"
								/>
						</TextBox>
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="4" Visibility="Hidden" KeyboardNavigation.TabNavigation="None">
						<Label Name="lblLkPetitionerOrganization" Content="Organizzazione" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<telerik:RadAutoCompleteBox 
							Name="cmbPetitionerOrganization"
							HorizontalAlignment="Stretch"
							SelectionMode="Single"
							TextSearchMode="StartsWith"
							TextSearchPath="Descrizione"					
							DisplayMemberPath="Descrizione"
							WatermarkContent="Organizzazione..."
							AutoCompleteMode="Suggest"							
							ItemsSource="{Binding AvailableOrganizations}"
							SelectedItem="{Binding ObjPetitionerOrganization, Mode=TwoWay}"
							SelectionChanged="cmbOrganization_SelectionChanged"
							Style="{StaticResource DataRadTextBox}"
							/>
					</DockPanel>
				</Grid>
				<Grid Grid.Row="3" Margin="3">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="25*"></ColumnDefinition>
						<ColumnDefinition Width="5*"></ColumnDefinition>
						<ColumnDefinition Width="15*"></ColumnDefinition>
						<ColumnDefinition Width="15*"></ColumnDefinition>
						<ColumnDefinition Width="30*"></ColumnDefinition>
					</Grid.ColumnDefinitions>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="0" KeyboardNavigation.TabNavigation="None">
						<Label Name="lblLCity" Content="Città" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<telerik:RadAutoCompleteBox 
							Name="cmbPetitionerCity"
							HorizontalAlignment="Stretch"
							Validation.Error="Validation_Error"														
							SelectionMode="Single"
							TextSearchMode="StartsWith"
							TextSearchPath="Nome"					
							DisplayMemberPath="Nome"
							WatermarkContent="Città..."
							AutoCompleteMode="Suggest"
							ItemsSource="{Binding AvailableCities}"
							SelectedItem="{Binding ObjPetitionerCity, Mode=TwoWay}"
							SelectionChanged="cmbCity_SelectionChanged"
							Style="{StaticResource ValidationRadAutoCompleteTextBox}"
							/>
					</DockPanel>
					<DockPanel Grid.Column="1" HorizontalAlignment="Stretch" KeyboardNavigation.TabNavigation="None">
						<Label Content="Cap" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtCap" Text="{Binding ObjPetitionerCity.CAP, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}" MaxLength="5" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel Grid.Column="2" HorizontalAlignment="Stretch" KeyboardNavigation.TabNavigation="None">
						<Label Content="Provincia" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtProvince" Text="{Binding ObjPetitionerCity.Provincia, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}" MaxLength="30" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel Grid.Column="3" HorizontalAlignment="Stretch" KeyboardNavigation.TabNavigation="None">
						<Label Content="Nazione" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtNazione" Text="{Binding ObjPetitionerCity.Nazione, Mode=TwoWay, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" MaxLength="30" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="4" KeyboardNavigation.TabNavigation="None">
						<Label Content="Indirizzo" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtIndirizzo" Text="{Binding ObjPetitioner.Indirizzo, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}" MaxLength="50" MinWidth="285" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
					</DockPanel>
				</Grid>
				<Grid Grid.Row="4" Margin="3">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="100*"></ColumnDefinition>
					</Grid.ColumnDefinitions>
					<StackPanel KeyboardNavigation.TabNavigation="None">
						<Label Content="Nota" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" />
						<TextBox 
							Name="txtNota" 
							Text="{Binding 
								ObjPetitioner.Nota, Mode=TwoWay,  
								ValidatesOnDataErrors=True, 
								NotifyOnValidationError=True}" 
							MaxLength="100" 
							AcceptsReturn="True" 
							TextWrapping="Wrap" 
							Height="40" 
							MinHeight="40" 
							VerticalScrollBarVisibility="Auto" 
							Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch"
							/>
					</StackPanel>
				</Grid>

			</Grid>
		</Border>

		<Border Name="brdPrenotation" Grid.Row="2" BorderBrush="Blue" BorderThickness="1" Background="#f1f1f1">
			<Grid x:Name="grdPrenotation" Margin="10">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
				</Grid.RowDefinitions>
				<Grid Grid.Row="0" Margin="3">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="14*"></ColumnDefinition>
						<ColumnDefinition Width="25*"></ColumnDefinition>
						<ColumnDefinition Width="25*"></ColumnDefinition>
						<ColumnDefinition Width="25*"></ColumnDefinition>
						<ColumnDefinition Width="14*"></ColumnDefinition>
						<ColumnDefinition Width="14*"></ColumnDefinition>
						<ColumnDefinition Width="14*"></ColumnDefinition>
					</Grid.ColumnDefinitions>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="0" KeyboardNavigation.TabNavigation="None">
						<Label Name="lblPrenotationDate" Content="Data prenotazione" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<telerik:RadDatePicker Name="dptPrenotationDate" Validation.Error="Validation_Error" SelectedValue="{Binding ObjPrenotation.Dt_Prenotazione, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}" Style="{StaticResource RadDatePicker}" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="1">
						<Label Name="lblResponseLanguage" Content="Lingua risposta" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<telerik:RadComboBox 
							Name="cmbPrenotationLanguage"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch"
							DisplayMemberPath="Descrizione"
							ItemsSource="{Binding AvailablePrenotationLanguages}"
							SelectedValue="{Binding ObjPrenotation.Id_LinguaRisposta, Mode=TwoWay}"
							SelectedValuePath="Id_Lingua"
							Style="{StaticResource ValidationRadComboBox}"
							/>
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="2" KeyboardNavigation.TabNavigation="None">
						<Label Name="lblVisitType" Content="Tipo visita" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<telerik:RadComboBox 
							Name="cmbPrenotationVisitType"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch"
    						TextSearchMode="Contains"
							DisplayMemberPath="Descrizione"
							ItemsSource="{Binding AvailableVisitTypes}"
							SelectedValue="{Binding ObjPrenotation.Id_TipoVisita, Mode=TwoWay, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
							SelectedValuePath="Id_TipoVisita"
							Style="{StaticResource ValidationRadComboBox}"
							/>
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="3" KeyboardNavigation.TabNavigation="None">
						<Label Name="lblConfirmationType" Content="Tipo conferma" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<telerik:RadComboBox 
							Name="cmbPrenotationConfirmationType"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch"
							TextSearchMode="Contains"
							DisplayMemberPath="Descrizione"
							ItemsSource="{Binding AvailableConfirmationTypes}"
							SelectedValue="{Binding ObjPrenotation.Id_TipoConferma, Mode=TwoWay, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
							SelectedValuePath="Id_TipoConferma"
							Style="{StaticResource ValidationRadComboBox}"
							/>
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="4">
						<Label Name="lblVisitors" Content="Totale visitatori" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<telerik:RadNumericUpDown
							Name="nudVisitors"
							Minimum="0"
							Maximum="999"
							Validation.Error="Validation_Error" 							
							Style="{StaticResource DataRadNumericUpDown}"
							NumberDecimalDigits="0"
							Value="{Binding 
								ObjPrenotation.Tot_Visitatori, 
								Mode=TwoWay, 
								ValidatesOnDataErrors=True,
								NotifyOnValidationError=True,
								UpdateSourceTrigger=PropertyChanged
								}"											
							/>
					</DockPanel>

					<DockPanel HorizontalAlignment="Stretch" Grid.Column="5">
						<Label Name="lblVisitDates1" Content="Visite dal" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<telerik:RadDatePicker Name="dtpVisitDate1" SelectedValue="{Binding ObjPrenotation.Dt_VisiteDA, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}" Style="{StaticResource RadDatePicker}" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="6">
						<Label Name="lblVisitDates2" Content="Al" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<telerik:RadDatePicker Name="dtpVisitDate2" SelectedValue="{Binding ObjPrenotation.Dt_VisiteA, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}" Style="{StaticResource RadDatePicker}" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="6" KeyboardNavigation.TabNavigation="None" Visibility="Collapsed">
						<Label Name="lblAM" Content="AM" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Center" DockPanel.Dock="Top" />
						<CheckBox Name="chkAM" IsThreeState="False" IsChecked="{Binding ObjPrenotation.Fl_AM, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}" VerticalAlignment="Bottom" HorizontalAlignment="Center" />
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="7" KeyboardNavigation.TabNavigation="None" Visibility="Collapsed">
						<Label Name="lblPM" Content="PM" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Center" DockPanel.Dock="Top" />
						<CheckBox Name="chkPM" IsThreeState="False" IsChecked="{Binding ObjPrenotation.Fl_PM, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}" VerticalAlignment="Bottom" HorizontalAlignment="Center" />
					</DockPanel>
				</Grid>
				<Grid Grid.Row="1" Margin="3">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="45*"></ColumnDefinition>
						<ColumnDefinition Width="45*"></ColumnDefinition>
						<ColumnDefinition Width="10*"></ColumnDefinition>
					</Grid.ColumnDefinitions>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="0" KeyboardNavigation.TabNavigation="None">
						<Label Name="lblPersonInCharge" Content="Visitatore responsabile" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtPersonInCharge" Validation.Error="Validation_Error" Style="{StaticResource DataTextBox}" MaxLength="50" HorizontalAlignment="Stretch" >
							<Binding
								Path="ObjPrenotation.Responsabile"
							    Mode="TwoWay"
								ValidatesOnDataErrors="True"
								NotifyOnValidationError="True"
								UpdateSourceTrigger="PropertyChanged"
								/>
						</TextBox>
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="1" KeyboardNavigation.TabNavigation="None">
						<Label Name="lblAuthorization" Content="Autorizzazione biglietti ridotti e omaggio" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtAuthorization" Text="{Binding Autorizzazione, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}" Style="{StaticResource DataTextBox}" MaxLength="50" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="3" KeyboardNavigation.TabNavigation="None">
						<Label Name="lblProtocol" Content="Protocollo" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtProtocol" Validation.Error="Validation_Error" Style="{StaticResource DataTextBox}" MaxLength="20" HorizontalAlignment="Stretch" IsEnabled="False">
							<Binding
									Path="ObjPrenotation.Protocollo"									
									ValidatesOnDataErrors="True"
									NotifyOnValidationError="True"
									UpdateSourceTrigger="PropertyChanged"
									>
							</Binding>
						</TextBox>
					</DockPanel>
				</Grid>
				<Grid Grid.Row="2" Margin="3" KeyboardNavigation.TabNavigation="None">
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="0">
						<Label Name="lblNote" Content="Nota" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox 
							Name="txtNote" 
							Text="{Binding 
								ObjPrenotation.Nota, Mode=TwoWay,  
								ValidatesOnDataErrors=True, 
								NotifyOnValidationError=True}" 
							MaxLength="100" 
							AcceptsReturn="True" 
							TextWrapping="Wrap" 
							Height="40" 
							MinHeight="40" 
							VerticalScrollBarVisibility="Auto" 
							Style="{StaticResource DataTextBox}" 
							HorizontalAlignment="Stretch"
							/>
					</DockPanel>
				</Grid>
			</Grid>
		</Border>

		<Border Name="brdVisits" Grid.Row="4" BorderBrush="Blue" BorderThickness="1" Background="#f1f1f1">
			<telerik:RadGridView
				Name="grdMaster" 
				Grid.Row="1"
				AutoGenerateColumns="False" 
				SelectionMode="Single"						
				ItemsSource="{Binding SrcPetitionerPrenotations}">
						
				<telerik:RadGridView.Columns>
					<telerik:GridViewDataColumn  Header="Protoc." IsReadOnly="True" IsFilterable="True"  ShowFilterButton="True"  DataMemberBinding="{Binding NProtocollo}"  Width="80*" />
						
					<telerik:GridViewDataColumn
						Header="Dt. Richiesta"
						DataMemberBinding="{Binding RequestDate, StringFormat=d, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"
						Width="80*"
						>
					</telerik:GridViewDataColumn>
						
					<telerik:GridViewDataColumn						
						Header="Visitatore"
						UniqueName="visitatore"
						DataMemberBinding="{Binding Responsabile}"
						Width="110*"
						/>

					<telerik:GridViewDataColumn 
						Header="Dt. visita"
						DataMemberBinding="{Binding Dt_Visita, StringFormat=d, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"
						Width="80*"
						/>
						
					<telerik:GridViewDataColumn 
						Header="Ling. visita"
						DataMemberBinding="{Binding LinguaVisita}"
						Width="80*"
						/>

					<telerik:GridViewDataColumn 
						Header="Pr. ora"
						DataMemberBinding="{Binding Ora_Visita}"
						Width="50*"
						/>

					<telerik:GridViewDataColumn 
						Header="Visitatori"
						DataMemberBinding="{Binding Tot_Visitatori}"
						Width="80"
						/>

					<telerik:GridViewDataColumn 
						Header="Ricevuta"
						DataMemberBinding="{Binding Ricevuta}"
						Width="80*"
						/>

					<telerik:GridViewDataColumn 
						Header="Dt. Ric."
						DataMemberBinding="{Binding Dt_Pagamento, StringFormat=d, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"
						Width="80*"
						/>

					<telerik:GridViewDataColumn 
						Header="Dt. risp."
						DataMemberBinding="{Binding Dt_InvioMailRichiedente, StringFormat=d, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"
						Width="80*"
						/>

					<telerik:GridViewDataColumn 
						Header="Tipo risposta"
						DataMemberBinding="{Binding TipoRisposta}"
						Width="140*"
						/>
				</telerik:RadGridView.Columns>
			</telerik:RadGridView>
		</Border>

		<Border Name="brdButtons" Grid.Row="6" BorderBrush="Blue" BorderThickness="1" Background="#f1f1f1">
			<Grid x:Name="grdButtons" Margin="3" >
				<StackPanel Orientation="Horizontal">
					<telerik:RadButton Name="btnSave" Content="Salva" Width="100" Height="25" />
					<telerik:RadButton Name="btnDelete" Content="Elimina" Width="100" Height="25" Visibility="Collapsed" />
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</my:BaseDetailPage>


