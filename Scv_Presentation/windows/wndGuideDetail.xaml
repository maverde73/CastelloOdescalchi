<my:BaseDetailPage 
	x:Class="Presentation.wndGuideDetail"
	xmlns:my1="clr-namespace:ShiftManager;assembly=ShiftManager"  
	xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
	xmlns:telerik2="clr-namespace:Telerik.Windows.Controls;assembly=Telerik.Windows.Controls" 
	xmlns:telerikGrid="clr-namespace:Telerik.Windows.Controls;assembly=Telerik.Windows.Controls.GridView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:my="clr-namespace:Presentation"
	xmlns:local="clr-namespace:Presentation"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    mc:Ignorable="d" 
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
	xmlns:ent="clr-namespace:Scv_Entities;assembly=Scv_Entities"
    Title="Guida" 
	Height="610" 
	MinHeight="650"
	Width="800"
	Icon="../Themes/Images/icons/logo_us_16x16.png"	
        
	>
	<Window.CommandBindings>
		<CommandBinding Command="New" CanExecute="Confirm_CanExecute" Executed="Confirm_Executed" />
	</Window.CommandBindings>

	<Window.Resources>
		<CollectionViewSource x:Key="cvsGuide" d:DesignSource="{d:DesignInstance ent:Guida, CreateList=True}" />
	</Window.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"></RowDefinition>
			<RowDefinition Height="5"></RowDefinition>
			<RowDefinition Height="100*"></RowDefinition>
			<RowDefinition Height="15"></RowDefinition>
			<RowDefinition Height="35"></RowDefinition>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="70*"></ColumnDefinition>
			<ColumnDefinition Width="30*"></ColumnDefinition>
		</Grid.ColumnDefinitions>

		<Border Name="brdGuide" Grid.Row="0" Grid.Column="0" BorderBrush="Blue" BorderThickness="1" Background="#f1f1f1">
			<Grid x:Name="grdGuide" Margin="10" >
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
					<RowDefinition Height="Auto"></RowDefinition>
				</Grid.RowDefinitions>
				<!-- Campi Guida-->
				<Grid Grid.Row="0" Margin="3" DataContext="{StaticResource cvsGuide}">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="30*"></ColumnDefinition>
						<ColumnDefinition Width="30*"></ColumnDefinition>
						<ColumnDefinition Width="15*"></ColumnDefinition>
					</Grid.ColumnDefinitions>
					<DockPanel Grid.Column="0" HorizontalAlignment="Stretch">
						<Label Content="Cognome" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtCognome" Validation.Error="Validation_Error" MaxLength="50" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch">
							<Binding
								Path="Cognome"
							    Mode="TwoWay"
								ValidatesOnDataErrors="True"
								NotifyOnValidationError="True"
								UpdateSourceTrigger="PropertyChanged"
								/>
						</TextBox>
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="1">
						<Label Content="Nome" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtNome" Validation.Error="Validation_Error" MaxLength="50" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch">
							<Binding
								Path="Nome"
							    Mode="TwoWay"
								ValidatesOnDataErrors="True"
								NotifyOnValidationError="True"
								UpdateSourceTrigger="PropertyChanged"
								/>
						</TextBox>
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="2">
						<Label Name="lblGuideTitle" Content="Titolo" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<telerik:RadComboBox 
							Name="cmbGuideTitle"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch"
							DisplayMemberPath="Sigla"
							ItemsSource="{Binding AvailableTitles}"
							SelectedValue="{Binding ObjGuide.Id_Titolo, Mode=TwoWay, ValidatesOnDataErrors=True, NotifyOnValidationError=True, UpdateSourceTrigger=PropertyChanged}"
							SelectedValuePath="Id_Titolo"
							Validation.Error="Validation_Error"							
							Style="{StaticResource DataRadComboBox}"
							/>
					</DockPanel>
				</Grid>
				<Grid Grid.Row="1" Margin="3" DataContext="{StaticResource cvsGuide}">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="70*"></ColumnDefinition>
						<ColumnDefinition Width="15*"></ColumnDefinition>
						<ColumnDefinition Width="15*"></ColumnDefinition>
					</Grid.ColumnDefinitions>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="0" Visibility="Hidden">
						<Label Name="lblLkCollege" Content="Collegio" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<telerik:RadComboBox 
							Name="cmbGuideCollege"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch"
							TextSearchMode="Contains"
							DisplayMemberPath="Descrizione"
							ItemsSource="{Binding AvailableColleges}"
							SelectedValue="{Binding ObjGuide.Id_Collegio, Mode=TwoWay, ValidatesOnDataErrors=True, NotifyOnValidationError=True, UpdateSourceTrigger=PropertyChanged}"
							SelectedValuePath="Id_Collegio"
							Validation.Error="Validation_Error"		
							Style="{StaticResource ValidationRadComboBox}"
							/>
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="1" Visibility="Hidden">
						<Label Name="lblCapofila" Content="Capofila" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Center" DockPanel.Dock="Top" />
						<CheckBox Name="chkCapofila" IsThreeState="False" IsChecked="{Binding Fl_Capofila, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}" VerticalAlignment="Bottom" HorizontalAlignment="Center" />
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="2">
						<Label Name="lblAttivo" Content="Attiva" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Center" DockPanel.Dock="Top" />
						<CheckBox Name="chkAttivo" IsThreeState="False" IsChecked="{Binding Fl_Attivo, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}" VerticalAlignment="Bottom" HorizontalAlignment="Center" />
					</DockPanel>
				</Grid>

				<Grid Grid.Row="2" Margin="3" DataContext="{StaticResource cvsGuide}">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="33*"></ColumnDefinition>
						<ColumnDefinition Width="33*"></ColumnDefinition>
						<ColumnDefinition Width="33*"></ColumnDefinition>
					</Grid.ColumnDefinitions>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="0" >
						<Label Content="Email" Grid.Column="9" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtEmail" Text="{Binding Email, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}"  MaxLength="50" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="1">
						<Label Content="Tel. Casa" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtTelefonoCasa" Text="{Binding Tel_Casa, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}" MaxLength="20" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel HorizontalAlignment="Stretch" Grid.Column="2">
						<Label Content="Tel. Cell." Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtTelCellulare" Text="{Binding Tel_Cellulare, Mode=TwoWay,  ValidatesOnDataErrors=True, NotifyOnValidationError=True}" MaxLength="20" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
					</DockPanel>
				</Grid>

				<Grid Grid.Row="3" Margin="3" DataContext="{StaticResource cvsGuide}">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="100*"></ColumnDefinition>
					</Grid.ColumnDefinitions>
					<StackPanel>
						<Label Content="Nota" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" />
						<TextBox 
							Name="txtNota" 
							Text="{Binding 
								Nota, Mode=TwoWay,  
								ValidatesOnDataErrors=True, 
								NotifyOnValidationError=True}" 
							MaxLength="100" 
							AcceptsReturn="True" 
							TextWrapping="Wrap" 
							Height="60" 
							MinHeight="60" 
							VerticalScrollBarVisibility="Auto" 
							Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch"
							/>
					</StackPanel>
				</Grid>
			</Grid>
		</Border>

		<Border Name="brdLanguages" Grid.Row="0" Grid.Column="1" BorderBrush="Blue" BorderThickness="1" Background="#f1f1f1" Margin="5,0,0,0">
			<Grid Margin="10">
				<Grid.RowDefinitions>
					<RowDefinition Height="40"></RowDefinition>
					<RowDefinition></RowDefinition>
				</Grid.RowDefinitions>
				<StackPanel>
					<CheckBox Name="chkAll" Content="Tutti" Checked="chkAll_Checked" Margin="55,0,0,0" />
					<StackPanel Grid.Column="0" Orientation="Horizontal" Margin="3">
						<TextBlock Text="(madre)" Margin="0,0,10,0" />
						<TextBlock Text="Lingua" />
					</StackPanel>
				</StackPanel>
				<ScrollViewer Grid.Row="1">
					<ListBox
						Name="lstLanguages"					
						HorizontalAlignment="Stretch"
						VerticalAlignment="Stretch"
						ItemsSource="{Binding AvailableLanguages}"
						Height="180"
						>
						<ListBox.ItemTemplate>
							<DataTemplate>
								<StackPanel Orientation="Horizontal">
									<StackPanel>
										<RadioButton 
											Name="RadDefaultLanguage"
											Content=""
											CommandParameter="{Binding Id_Lingua}"
											IsChecked="{Binding IsDefault}"
											GroupName="Default"
											Checked="radDefaultLanguage_Click"
											Margin="15,0,20,0"
										/>
									</StackPanel>
									<StackPanel>
										<CheckBox 
											Name="chkLanguage"
											Content="{Binding Descrizione}"
											Tag="{Binding Descrizione}"
											IsChecked="{Binding IsSelected}"
										/>
									</StackPanel>
								</StackPanel>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</ScrollViewer>
			</Grid>
		</Border>

		<Border Name="brdAvailability" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="Blue" BorderThickness="1" Background="#f1f1f1">
			<my1:ShiftManager Name="ShiftMng" />
		</Border>

		<Border Name="brdButtons" Grid.Row="4" BorderBrush="#ffffff" BorderThickness="0" Background="#ffffff">
			<Grid x:Name="grdButtons" Margin="3" >
				<StackPanel Orientation="Horizontal">
					<telerik:RadButton Name="btnSave" Content="Salva" Width="100" Height="25" />
					<telerik:RadButton Name="btnDelete" Content="Elimina" Width="100" Height="25" />
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</my:BaseDetailPage>


