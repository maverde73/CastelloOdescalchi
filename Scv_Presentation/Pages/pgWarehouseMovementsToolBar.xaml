<my:BaseToolBarPage 
	x:Class="Presentation.Pages.pgWarehouseMovementsToolBar"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    mc:Ignorable="d" 
    d:DesignHeight="300" d:DesignWidth="300"
	xmlns:my="clr-namespace:Presentation"
	Title="Guide">

	<Grid>
		<telerik:RadRibbonView
			Name="rib"
			Title="Movimenti"
			ApplicationName="Scv"
			VerticalAlignment="top"
			HorizontalAlignment="Stretch"
			TitleBarVisibility="Collapsed"
			>
			<telerik:RadRibbonTab Header="Home">
				<telerik:RadRibbonGroup Header="Movimenti Magazzino">
					<telerik:RadRibbonButton 
							Name="btnNew" 
							Width="Auto"
							Height="55" 
							BorderThickness="0.3" 
							HorizontalContentAlignment="Center" 
							Padding="3" 
							Margin="3,0,0,0"
							>
						<StackPanel Width="70" Height="55" Orientation="Vertical">
							<Image Width="16" Height="16" Source="/Themes/Images/ButtonIcons/newTableItem_16.png" Stretch="Fill"/>
							<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Nuovo" TextWrapping="Wrap"/>
						</StackPanel>
					</telerik:RadRibbonButton>
					
					<!--<telerik:RadRibbonButton 
						Name="btnDelete" 
						Width="Auto"
						Height="55" 
						BorderThickness="0.3" 
						HorizontalContentAlignment="Left" 
						Padding="3"
						Margin="0,0,3,0"
						>
						<StackPanel Width="50" Height="55" Orientation="Vertical">
							<Image Width="16" Height="16" Source="/Themes/Images/ButtonIcons/DeleteItem_16.png" Stretch="Fill"/>
							<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Elimina" TextWrapping="Wrap"/>
						</StackPanel>
					</telerik:RadRibbonButton>-->

					<telerik:RadRibbonButton 
						Name="btnPrint" 
						Width="Auto"
						Height="55" 
						BorderThickness="0.3" 
						HorizontalContentAlignment="Left" 
						Padding="3"
						Margin="0,0,3,0"
						>
						<StackPanel Width="70" Height="55" Orientation="Vertical">
							<Image Width="16" Height="16" Source="/Themes/Images/ButtonIcons/print_16.png" Stretch="Fill"/>
							<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Stampa" TextWrapping="Wrap"/>
						</StackPanel>
					</telerik:RadRibbonButton>

					<telerik:RadRibbonButton 
						Name="btnPrintAll" 
						Width="Auto"
						Height="55" 
						BorderThickness="0.3" 
						HorizontalContentAlignment="Left" 
						Padding="3"
						Margin="0,0,3,0"
						>
						<StackPanel Width="70" Height="55" Orientation="Vertical">
							<Image Width="16" Height="16" Source="/Themes/Images/ButtonIcons/print_16.png" Stretch="Fill"/>
							<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Stampa tutto" TextWrapping="Wrap"/>
						</StackPanel>
					</telerik:RadRibbonButton>

					<telerik:RadRibbonButton 
						Name="btnChangeMovementPaymentType" 
						Width="Auto"
						Height="55" 
						BorderThickness="0.3" 
						HorizontalContentAlignment="Left" 
						Padding="3"
						Margin="0,0,3,0"
						>
						<StackPanel Width="70" Height="55" Orientation="Vertical">
							<Image Width="16" Height="16" Source="/Themes/Images/ButtonIcons/print_16.png" Stretch="Fill"/>
							<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Cambia tipo pagamento" TextWrapping="Wrap"/>
						</StackPanel>
					</telerik:RadRibbonButton>

				</telerik:RadRibbonGroup>
			</telerik:RadRibbonTab>
		</telerik:RadRibbonView>
	</Grid>
</my:BaseToolBarPage>
