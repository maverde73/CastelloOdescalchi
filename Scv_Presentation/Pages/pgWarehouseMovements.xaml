<my:BaseContentPage 
	x:Class="Presentation.Pages.pgWarehouseMovements"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
	xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
	xmlns:sysglb="clr-namespace:System.Globalization;assembly=mscorlib"		
    mc:Ignorable="d" 
    d:DesignHeight="300" d:DesignWidth="800"
	xmlns:my="clr-namespace:Presentation"
	xmlns:ent="clr-namespace:Scv_Entities;assembly=Scv_Entities"
	Title="Guide">
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="60"></RowDefinition>
			<RowDefinition Height="100*"></RowDefinition>
			<RowDefinition Height="30"></RowDefinition>
		</Grid.RowDefinitions>
		<Border Name="brdFilter" Grid.Row="0" BorderBrush="Blue" BorderThickness="1" Background="#f1f1f1">
			<StackPanel Orientation="Horizontal" Margin="5">
				<StackPanel>
					<Label Content="Dal"></Label>
					<StackPanel Orientation="Horizontal">
						<telerik:RadDatePicker Name="dtpDate1"  MinWidth="120"></telerik:RadDatePicker>
						<telerik:RadButton Name="btnCancelDate1" Content="non filtrare"></telerik:RadButton>
					</StackPanel>
				</StackPanel>
				<StackPanel Margin="5,0,0,0">
					<Label Content="Al"></Label>
					<StackPanel Orientation="Horizontal">
						<telerik:RadDatePicker Name="dtpDate2" MinWidth="120"></telerik:RadDatePicker>
						<telerik:RadButton Name="btnCancelDate2" Content="non filtrare"></telerik:RadButton>
					</StackPanel>
				</StackPanel>
				<StackPanel Margin="5,0,0,0">
					<Label Content="Tipo movimento"></Label>
					<telerik:RadComboBox 
						Name="cmbTipoMovimento" 
						MinWidth="200"
						Style="{StaticResource ValidationRadComboBox}" 
						ItemsSource="{Binding AvailableMovementTypes}"
						SelectedValue="{Binding SelectedMovementTypeID, Mode=TwoWay}"						
						DisplayMemberPath="Descrizione"
						SelectedValuePath="Id_TipoMovimento"						
						/>
				</StackPanel>
				<StackPanel Orientation="Horizontal" Margin="5,0,0,0">
					<telerik:RadButton Name="btnFilter"  Content="Filtra" MinWidth="100"/>
					<telerik:RadButton Name="btnCancel"  Content="Elimina filtri" MinWidth="100"/>
				</StackPanel>
			</StackPanel>
		</Border>
		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
			<telerik:RadGridView	
				Name="grdMaster" 
				AutoGenerateColumns="False" 
				VerticalAlignment="Top"
				HorizontalAlignment="Stretch"
				SelectionMode="Single"
				ItemsSource="{Binding MasterList}"	
				ScrollViewer.VerticalScrollBarVisibility="Auto"
				ScrollMode="RealTime"
				ShowGroupPanel="false"
				IsReadOnly="True"
				RowLoaded="grdMaster_RowLoaded"				
				>
				<telerik:RadGridView.Columns>
					<telerik:GridViewToggleRowDetailsColumn />
					<telerik:GridViewDataColumn
						Header="Tipo movimento"
						DataMemberBinding="{Binding MovementType}"
						Width="210"
						ShowFilterButton="False"
						/>

					<telerik:GridViewDataColumn
						Header="Data"
						DataMemberBinding="{Binding Date, StringFormat=d, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"
						Width="70"
						ShowFilterButton="False"
						/>

					<telerik:GridViewDataColumn
						Header="Bolla"
						DataMemberBinding="{Binding Document}"
						Width="80"
						ShowFilterButton="False"
						/>

					<telerik:GridViewDataColumn
						Header="Tipo pagamento"
						DataMemberBinding="{Binding PaymentType}"
						Width="100"
						ShowFilterButton="False"
						/>

					<telerik:GridViewDataColumn
						Header="Esercizio vendita."
						DataMemberBinding="{Binding Store}"
						Width="150"
						ShowFilterButton="False"
						/>

					<telerik:GridViewDataColumn
						Header="Sconto"
						DataMemberBinding="{Binding StoreDiscount, StringFormat={}{0}%}"
						Width="75"
						ShowFilterButton="False"
						/>

					<telerik:GridViewDataColumn
						Header="Totale"
						DataMemberBinding="{Binding Total, StringFormat=c, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"
						Width="75"
						ShowFilterButton="False"
						/>

					<telerik:GridViewDataColumn
						Header="Nota"
						DataMemberBinding="{Binding MovementNote}"
						Width="240"
						ShowFilterButton="False"
						/>

				</telerik:RadGridView.Columns>
				<telerik:RadGridView.RowDetailsTemplate>
					<DataTemplate>
						<telerik:RadGridView
							Margin="20,0,10,10"
							Name="grdDetails"
							AutoGenerateColumns="False" 
							VerticalAlignment="Top"
							HorizontalAlignment="Stretch"					
							SelectionMode="Single"
							ScrollViewer.VerticalScrollBarVisibility="Auto"
							ScrollMode="RealTime"
							ShowGroupPanel="false"	
							IsReadOnly="True"
							Background="White"
							ItemsSource="{Binding}" >
							<telerik:RadGridView.Columns>
								<telerik:GridViewDataColumn 
									Header="ISBN"
									DataMemberBinding="{Binding ISBN}"
									Width="100"
									ShowFilterButton="False"
									/>

								<telerik:GridViewDataColumn
									Header="Articolo"
									DataMemberBinding="{Binding Article}"
									Width="200"
									ShowFilterButton="False"
									/>

								<telerik:GridViewDataColumn
									Header="Tipo Articolo"
									DataMemberBinding="{Binding ArticleType}"
									Width="150"
									ShowFilterButton="False"
									/>

								<telerik:GridViewDataColumn
									Header="Nr.Pezzi"
									DataMemberBinding="{Binding Quantity}"
									Width="100"
									ShowFilterButton="False"
									/>

								<telerik:GridViewDataColumn
									Header="Pr. Pubblico"
									DataMemberBinding="{Binding PublicPrice, StringFormat=C, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"
									Width="80"
									ShowFilterButton="False"
									/>

								<telerik:GridViewDataColumn
									Header="Pr. scontato"
									DataMemberBinding="{Binding Price, StringFormat=C, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"
									Width="80"
									ShowFilterButton="False"
									/>

								<telerik:GridViewDataColumn
									Header="totale."
									DataMemberBinding="{Binding Total, StringFormat=C, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"                    
									Width="100"
									ShowFilterButton="False"
									/>
							</telerik:RadGridView.Columns>
						</telerik:RadGridView>
					</DataTemplate>
				</telerik:RadGridView.RowDetailsTemplate>
				<telerik:RadContextMenu.ContextMenu>
					<telerik:RadContextMenu 
						x:Name="ContextMenu" 
						ItemClick="contextMenu_Click" 
						Opening="contextMenu_Opening">
						<telerik:RadMenuItem Name="mnuPrint" Header="Stampa" CommandParameter="print">
							<telerik:RadMenuItem.IconTemplate>
								<DataTemplate>
									<Image Source="../Themes/Images/ButtonIcons/print_16.png" Stretch="UniformToFill"/>
								</DataTemplate>
							</telerik:RadMenuItem.IconTemplate>
						</telerik:RadMenuItem>
						<!--<telerik:RadMenuItem Name="mnuDelete" Header="Elimina" CommandParameter="delete" >
							<telerik:RadMenuItem.IconTemplate>
								<DataTemplate>
									<Image Source="../Themes/Images/ButtonIcons/DeleteItem_16.png" Stretch="UniformToFill"/>
								</DataTemplate>
							</telerik:RadMenuItem.IconTemplate>
						</telerik:RadMenuItem>-->
						<telerik:RadMenuItem Name="mnuChangeMovementPaymentType" Header="Cambia tipo pagamento" CommandParameter="changeMovementPaymentType" >
							<telerik:RadMenuItem.IconTemplate>
								<DataTemplate>
									<Image Source="../Themes/Images/ButtonIcons/DeleteItem_16.png" Stretch="UniformToFill"/>
								</DataTemplate>
							</telerik:RadMenuItem.IconTemplate>
						</telerik:RadMenuItem>
					</telerik:RadContextMenu>
				</telerik:RadContextMenu.ContextMenu>
			</telerik:RadGridView>
		</ScrollViewer>
		<telerik:RadDataPager 
			Name="gridPager"
			Grid.Row="2"
            Source="{Binding Items, ElementName=grdMaster}"
            DisplayMode="All"
			AutoEllipsisMode="Both"
			NumericButtonCount="10"
			IsTotalItemCountFixed="True"
			/>

	</Grid>
</my:BaseContentPage>
