<my:BaseContentPage 
    xmlns:my2="clr-namespace:CustomPagerManager;assembly=CustomPagerManager"  
	x:Class="Presentation.Pages.pgEvidenzeGiornaliere"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
	xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns:helpers="clr-namespace:Presentation.Helpers"	
	xmlns:sysglb="clr-namespace:System.Globalization;assembly=mscorlib"		
	xmlns:my1="clr-namespace:Presentation.CustomControls.PaymentLib" 
    xmlns:cpg="clr-Namespace:CustomPageManager"
	xmlns:vs="clr-namespace:VisitsSummaryManager;assembly=VisitsSummaryManager" 	
    mc:Ignorable="d" 
    d:DesignHeight="300" 
	d:DesignWidth="800"
	xmlns:my="clr-namespace:Presentation"
	Title="pgPetitioners">
    <Grid Margin="10" VirtualizingStackPanel.VirtualizationMode="Recycling">
        <Grid.Resources>
            <SolidColorBrush Color="White" x:Key="BgFallback"/>
            <SolidColorBrush Color="White" x:Key="BgNull"/>
            <SolidColorBrush x:Key="GridLine" Color="#a1a1a1" />
            <Style x:Key="GridViewRowStyle" TargetType="{x:Type telerik:GridViewRow}">
                <Setter Property="Background" Value="{Binding BgColor, FallbackValue={StaticResource BgFallback}}"/>
                <Setter Property="SelectiveScrollingGrid.Background" Value="{Binding BgColor, FallbackValue={StaticResource BgFallback}}"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="55"></RowDefinition>
            <RowDefinition Height="100*"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
        </Grid.RowDefinitions>
        <Border Name="brdFilter" Grid.Row="0" BorderBrush="Blue" BorderThickness="1" Background="#f1f1f1">
            <StackPanel Orientation="Horizontal" Margin="1">
                <StackPanel>
                    <Label Content="Protocollo"></Label>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Name="txtReference" MinWidth="100"></TextBox>
                        <telerik:RadButton Name="btnCancelReference" Content="non filtrare"></telerik:RadButton>
                    </StackPanel>
                </StackPanel>

                <StackPanel>
                    <Label Content="Visite dal"></Label>
                    <StackPanel Orientation="Horizontal">
                        <telerik:RadDatePicker Name="dtpDate1" MinWidth="90"></telerik:RadDatePicker>
                        <telerik:RadButton Name="btnCancelDate1" Content="non filtrare"></telerik:RadButton>
                    </StackPanel>
                </StackPanel>
                <StackPanel Margin="5,0,0,0">
                    <Label Content="al"></Label>
                    <StackPanel Orientation="Horizontal">
                        <telerik:RadDatePicker Name="dtpDate2" MinWidth="90"></telerik:RadDatePicker>
                        <telerik:RadButton Name="btnCancelDate2" Content="non filtrare"></telerik:RadButton>
                    </StackPanel>
                </StackPanel>
                <StackPanel Margin="5,0,0,0">
                    <Label Content="Stato visite"></Label>
                    <telerik:RadComboBox 
						Name="cmbTipoMovimento" 
						MinWidth="100"
						Style="{StaticResource ValidationRadComboBox}" 
						ItemsSource="{Binding AvailableStatusTypes}"
						SelectedValue="{Binding SelectedStatusTypeID, Mode=TwoWay}"						
						DisplayMemberPath="Descrizione"
						SelectedValuePath="Id_TipoRisposta"						
						/>
                </StackPanel>
                <StackPanel>
                    <Label Content="Numero Ordine"></Label>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Name="txtNumeroOrdine" MinWidth="100"></TextBox>
                        <telerik:RadButton Name="btnCancelNumeroOrdine" Content="non filtrare"></telerik:RadButton>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                    <telerik:RadButton Name="btnFilter"  Content="Filtra" IsDefault="True" MinWidth="80"/>
                    <telerik:RadButton Name="btnExportExcel"  Content="Esporta in Excel" IsDefault="True" MinWidth="80"/>
                    <telerik:RadButton Name="btnCancel"  Content="Elimina filtri" MinWidth="80"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <telerik:RadGridView 
			Name="grdMaster" 
			Grid.Row="1"
			AutoGenerateColumns="False" 
			SelectionMode="Single"
			ShowGroupPanel="False"
			CanUserSortColumns="False"
			ItemsSource="{Binding SrcEvidenzeGiornaliere}"	
			FilterOperatorsLoading="grdMaster_FilterOperatorsLoading"
            GroupRowIsExpandedChanged="grdMaster_GroupRowIsExpandedChanged"
            SelectionUnit ="FullRow"
            IsReadOnly="True"
            RowStyle="{StaticResource GridViewRowStyle}">

            <telerik:RadGridView.Columns>
                <telerik:GridViewDataColumn Header="Data" IsReadOnly="True" IsFilterable="False" ShowFilterButton="False" Width="70*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding VisitDate, FallbackValue='', StringFormat=d, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"  Visibility="{Binding ColumnVisibility, FallbackValue=Visible}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn UniqueName="ora" Header="Ora" IsReadOnly="True" IsFilterable="True" ShowFilterButton="True" DataMemberBinding="{Binding Ora_Visita, FallbackValue=''}"  Width="45*" >
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Ora_Visita, FallbackValue=''}" Visibility="{Binding ColumnVisibility, FallbackValue=Visible}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn UniqueName="lingua"  Header="Lingua" IsReadOnly="True" IsFilterable="True" ShowFilterButton="True" DataMemberBinding="{Binding LinguaVisita, FallbackValue=''}" Width="55*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding LinguaVisita, FallbackValue=''}" Visibility="{Binding ColumnVisibility, FallbackValue=Visible}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn UniqueName="nominativo"  Header="Guida" IsReadOnly="True" IsFilterable="True" ShowFilterButton="True" DataMemberBinding="{Binding Nominativo, FallbackValue=''}"  Width="80*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Nominativo, FallbackValue=''}" Visibility="{Binding ColumnVisibility, FallbackValue=Visible}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn
					Header="Acc."
					DataMemberBinding="{Binding Fl_AccettaGuida, Mode=TwoWay}"
					IsFilterable="False" 
					ShowFilterButton="False"
					Width="35*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding AccettaGuida, FallbackValue=False}" Visibility="{Binding ColumnVisibility, FallbackValue=Visible}"/>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Ult. avviso" IsReadOnly="True" IsFilterable="False" ShowFilterButton="False"  Width="70*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Dt_InvioAvviso, FallbackValue='', StringFormat=d, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn UniqueName="tipovisita"  Header="T.V." IsReadOnly="True" IsFilterable="True"  ShowFilterButton="True" DataMemberBinding="{Binding TipoVisita, FallbackValue=''}" Width="40*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TipoVisita, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="T.vis." IsReadOnly="True" IsFilterable="False"  ShowFilterButton="False"  Width="35*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NumeroVisitatoriGruppo, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn UniqueName="protocollo"   Header="Protoc." IsReadOnly="True" IsFilterable="True" ShowFilterButton="True" DataMemberBinding="{Binding NProtocollo, FallbackValue=''}"  Width="60*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NProtocollo, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <!--<telerik:GridViewDataColumn Header="Dt. risp."	DataMemberBinding="{Binding Dt_InvioMailRichiedente, StringFormat=d, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"	Width="80*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Dt_InvioMailRichiedente, FallbackValue='', StringFormat=d, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>-->

                <telerik:GridViewDataColumn
					Header="Cnf."
					IsFilterable="False"
					IsReadOnly="true"
					ShowFilterButton="False"
					Width="35*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Fl_Conferma, FallbackValue=False}" IsEnabled="False" />
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Int."  IsReadOnly="True" IsFilterable="False" ShowFilterButton="False" Width="30*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Nr_Interi, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Rid." IsReadOnly="True" IsFilterable="False" ShowFilterButton="False" Width="30*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Nr_Ridotti, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Om." IsReadOnly="True" IsFilterable="False" ShowFilterButton="False" Width="30*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Nr_Omaggio, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Em." IsReadOnly="True" IsFilterable="False"  ShowFilterButton="False"  Width="35*">
                    <telerik:GridViewDataColumn.CellStyle>
                        <Style TargetType="telerik:GridViewCell">
                            <Setter Property="Foreground"  Value="Red" />
                        </Style>
                    </telerik:GridViewDataColumn.CellStyle>
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Consegnati, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn UniqueName="visitatore"  Header="Visitatore" IsReadOnly="True" IsFilterable="True" ShowFilterButton="True" DataMemberBinding="{Binding Responsabile, FallbackValue=''}" Width="95*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Responsabile, FallbackValue=''}" ></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Ricevuta" IsReadOnly="True" IsFilterable="False" ShowFilterButton="False" Width="80*">
                    <telerik:GridViewDataColumn.CellStyle>
                        <Style TargetType="telerik:GridViewCell">
                            <Setter Property="Foreground"  Value="Red" />
                        </Style>
                    </telerik:GridViewDataColumn.CellStyle>
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Ricevuta, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Importo" IsReadOnly="True" IsFilterable="False"  ShowFilterButton="False" Width="75*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Importo, FallbackValue=0, StringFormat=C, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>
                <telerik:GridViewDataColumn  Header="Pag." IsReadOnly="True" IsFilterable="True"  ShowFilterButton="True" Width="33*" DataMemberBinding="{Binding Simbolo, FallbackValue=''}">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Simbolo, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Dt. pagam." IsReadOnly="True" IsFilterable="True"  ShowFilterButton="False" Width="70*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Dt_Pagamento, FallbackValue='', StringFormat=d, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

            </telerik:RadGridView.Columns>

            <telerik:RadContextMenu.ContextMenu>
                <telerik:RadContextMenu 
					x:Name="ContextMenu" 
					ItemClick="contextMenu_Click" 
					Opening="contextMenu_Opening">
                    <telerik:RadMenuItem Name="mnuCancel" Header="Annulla prenotazione" CommandParameter="cancel">
                        <telerik:RadMenuItem.IconTemplate>
                            <DataTemplate>
                                <Image Source="../Themes/Images/ButtonIcons/DeleteItem_16.png" Stretch="UniformToFill"/>
                            </DataTemplate>
                        </telerik:RadMenuItem.IconTemplate>
                    </telerik:RadMenuItem>
                </telerik:RadContextMenu>
            </telerik:RadContextMenu.ContextMenu>

        </telerik:RadGridView>
        <telerik:RadDataPager 
				Name="gridPager"
				Grid.Row="2"
				Source="{Binding Items, ElementName=grdMaster}"
				DisplayMode="All"
				AutoEllipsisMode="Both"
				NumericButtonCount="10"
				IsTotalItemCountFixed="True"
				PageIndexChanged="gridPager_PageIndexChanged"
				/>

    </Grid>
</my:BaseContentPage>