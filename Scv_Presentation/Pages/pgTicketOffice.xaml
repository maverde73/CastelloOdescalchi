<my:BaseContentPage
    xmlns:my2="clr-namespace:CustomPagerManager;assembly=CustomPagerManager"  
	x:Class="Presentation.Pages.pgTicketOffice"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
	xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns:helpers="clr-namespace:Presentation.Helpers"	
	xmlns:sysglb="clr-namespace:System.Globalization;assembly=mscorlib"	
	xmlns:vs="clr-namespace:VisitsSummaryManager;assembly=VisitsSummaryManager"	
    mc:Ignorable="d" 
    d:DesignHeight="300" 
	d:DesignWidth="800"
	xmlns:my="clr-namespace:Presentation"
	Title="pgPetitioners">
	<Grid Margin="10" VirtualizingStackPanel.VirtualizationMode="Recycling">
		<Grid.Resources>
			<SolidColorBrush Color="White" x:Key="BgFallback"/>
			<SolidColorBrush Color="White" x:Key="BgNull"/>
			<SolidColorBrush x:Key="GridLine" Color="#a1a1a1" />
            <Style x:Key="GridViewRowStyle" TargetType="{x:Type telerik:GridViewRow}">
                <Setter Property="Background" Value="{Binding BgColor, FallbackValue={StaticResource BgFallback}}"/>
                <Setter Property="SelectiveScrollingGrid.Background" Value="{Binding BgColor, FallbackValue={StaticResource BgFallback}}"/>
            </Style>
        </Grid.Resources>

		<Grid.RowDefinitions>
			<RowDefinition Height="55" Name="row1"></RowDefinition>
			<RowDefinition Height="100*" Name="row2"></RowDefinition>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="108"></ColumnDefinition>
			<ColumnDefinition Width="108"></ColumnDefinition>
			<ColumnDefinition Width="108"></ColumnDefinition>
			<ColumnDefinition></ColumnDefinition>
			<ColumnDefinition></ColumnDefinition>
		</Grid.ColumnDefinitions>
		<StackPanel Grid.Column="0" Grid.Row="0">
			<Label Content="Data visite"></Label>
			<telerik:RadDatePicker Name="dtpDate1" SelectedValue="{Binding VisitDate, Mode=TwoWay}" MinWidth="90"></telerik:RadDatePicker>
		</StackPanel>
		<Border Grid.Column="1" Grid.Row="0" BorderBrush="Gray" BorderThickness="0.5" Width="100" HorizontalAlignment="Left" Margin="5,0,0,0">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition></ColumnDefinition>
					<ColumnDefinition></ColumnDefinition>
					<ColumnDefinition></ColumnDefinition>
				</Grid.ColumnDefinitions>
				<Grid.RowDefinitions>
					<RowDefinition></RowDefinition>
					<RowDefinition></RowDefinition>
				</Grid.RowDefinitions>
				<Border Grid.Column="0" Grid.Row="0" BorderBrush="LightGray" BorderThickness="0.5">
					<StackPanel>
						<TextBlock Text="Int." TextAlignment="Center" FontWeight="Bold" FontSize="10"></TextBlock>
						<TextBlock Text="{Binding TotaleInteriEmessi}" TextAlignment="Center" FontWeight="Bold" FontSize="10"></TextBlock>
					</StackPanel>
				</Border>
				<Border Grid.Column="1" Grid.Row="0" BorderBrush="LightGray" BorderThickness="0.5">
					<StackPanel>
						<TextBlock Text="Rid." TextAlignment="Center" FontWeight="Bold" FontSize="10"></TextBlock>
						<TextBlock Text="{Binding TotaleRidottiEmessi}" TextAlignment="Center" FontWeight="Bold" FontSize="10"></TextBlock>
					</StackPanel>
				</Border>
				<Border  Grid.Column="2" Grid.Row="0" BorderBrush="LightGray" BorderThickness="0.5">
					<StackPanel Grid.Column="2" Grid.Row="0">
						<TextBlock Text="Oma." TextAlignment="Center" FontWeight="Bold" FontSize="10"></TextBlock>
						<TextBlock Text="{Binding TotaleOmaggioEmessi}" TextAlignment="Center" FontWeight="Bold" FontSize="10"></TextBlock>
					</StackPanel>
				</Border>
				<Label Content="{Binding TotaleBigliettiEmessi}" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3" FontWeight="Bold" Style="{StaticResource CaptionLabel}" FontSize="10" HorizontalAlignment="Stretch"></Label>
			</Grid>
		</Border>
		<Border Grid.Column="2" Grid.Row="0" BorderBrush="Gray" BorderThickness="0.5" Width="100" HorizontalAlignment="Left">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition></ColumnDefinition>
					<ColumnDefinition></ColumnDefinition>
					<ColumnDefinition></ColumnDefinition>
				</Grid.ColumnDefinitions>
				<Grid.RowDefinitions>
					<RowDefinition></RowDefinition>
					<RowDefinition></RowDefinition>
				</Grid.RowDefinitions>
				<Border Grid.Column="0" Grid.Row="0" BorderBrush="LightGray" BorderThickness="0.5">
					<StackPanel>
						<TextBlock Text="Int." TextAlignment="Center" FontWeight="Bold" FontSize="10"></TextBlock>
						<TextBlock Text="{Binding TotaleInteri}" TextAlignment="Center" FontWeight="Bold" FontSize="10"></TextBlock>
					</StackPanel>
				</Border>
				<Border Grid.Column="1" Grid.Row="0" BorderBrush="LightGray" BorderThickness="0.5">
					<StackPanel>
						<TextBlock Text="Rid." TextAlignment="Center" FontWeight="Bold" FontSize="10"></TextBlock>
						<TextBlock Text="{Binding TotaleRidotti}" TextAlignment="Center" FontWeight="Bold" FontSize="10"></TextBlock>
					</StackPanel>
				</Border>
				<Border  Grid.Column="2" Grid.Row="0" BorderBrush="LightGray" BorderThickness="0.5">
					<StackPanel Grid.Column="2" Grid.Row="0">
						<TextBlock Text="Oma." TextAlignment="Center" FontWeight="Bold" FontSize="10"></TextBlock>
						<TextBlock Text="{Binding TotaleOmaggio}" TextAlignment="Center" FontWeight="Bold" FontSize="10"></TextBlock>
					</StackPanel>
				</Border>				
				<Label Content="{Binding TotaleBiglietti}" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3" FontWeight="Bold" Style="{StaticResource CaptionLabel}" FontSize="10" HorizontalAlignment="Stretch"></Label>
			</Grid>
		</Border>
		<Border Grid.Column="3" Grid.Row="0" BorderBrush="Gray" BorderThickness="0.5" HorizontalAlignment="Left">
			<StackPanel>
				<TextBlock Text="Totali emessi/lingue"></TextBlock>
				<ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Auto">
					<vs:VisitTotal x:Name="vTotal"></vs:VisitTotal>
				</ScrollViewer>
			</StackPanel>
		</Border>
		<TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding SelectedItem.NotaPrenotazione}" TextAlignment="Left" FontWeight="Bold" FontSize="14" Foreground="Red" Margin="10,5,5,5"></TextBlock>
        <telerik:RadGridView 
			Name="grdMaster" 
			Grid.Row="1"
			Grid.Column="0"
			Grid.ColumnSpan="5"
			AutoGenerateColumns="False"
			SelectionMode="Single"
			ShowGroupPanel="False"
			CanUserSortColumns="False" 
            SelectionUnit ="FullRow"
            IsReadOnly="True"
            RowStyle="{StaticResource GridViewRowStyle}"  
			SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
			ItemsSource="{Binding SrcEvidenzeGiornaliere}">
            <telerik:RadGridView.Columns>
                <telerik:GridViewDataColumn Header="Data" IsReadOnly="True" IsFilterable="False" ShowFilterButton="False" Width="70*">

                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding VisitDate, FallbackValue='', StringFormat=d, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}" Visibility="{Binding ColumnVisibility, FallbackValue=Visible}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn UniqueName="ora" Header="Ora" IsReadOnly="True" IsFilterable="True" ShowFilterButton="True" DataMemberBinding="{Binding Ora_Visita, FallbackValue=''}"  Width="45*" >
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Ora_Visita, FallbackValue=''}" Visibility="{Binding ColumnVisibility, FallbackValue=Visible}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>


                <telerik:GridViewDataColumn UniqueName="lingua"  Header="Lingua" IsReadOnly="True" IsFilterable="True" ShowFilterButton="True" DataMemberBinding="{Binding LinguaVisita, FallbackValue=''}" Width="55*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding LinguaVisita, FallbackValue=''}" Visibility="{Binding ColumnVisibility, FallbackValue=Visible}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>


                <telerik:GridViewDataColumn UniqueName="nominativo"  Header="Guida" IsReadOnly="True" IsFilterable="True" ShowFilterButton="True" DataMemberBinding="{Binding Nominativo, FallbackValue=''}"  Width="80*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Nominativo, FallbackValue=''}" Visibility="{Binding ColumnVisibility, FallbackValue=Visible}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn UniqueName="tipovisita"  Header="T.V." IsReadOnly="True" IsFilterable="True"  ShowFilterButton="True" DataMemberBinding="{Binding TipoVisita, FallbackValue=''}" Width="40*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TipoVisita, FallbackValue=''}" Visibility="{Binding ColumnVisibility, FallbackValue=Visible}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="T.vis." IsReadOnly="True" IsFilterable="False"  ShowFilterButton="False"  Width="35*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NumeroVisitatoriGruppo, FallbackValue=''}" Visibility="{Binding ColumnVisibility, FallbackValue=Visible}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn UniqueName="protocollo"   Header="Protoc." IsReadOnly="True" IsFilterable="True" ShowFilterButton="True" DataMemberBinding="{Binding NProtocollo, FallbackValue=''}"  Width="60*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NProtocollo, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Int."  IsReadOnly="True" IsFilterable="False" ShowFilterButton="False" Width="30*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Nr_Interi, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Rid." IsReadOnly="True" IsFilterable="False" ShowFilterButton="False" Width="30*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Nr_Ridotti, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Om." IsReadOnly="True" IsFilterable="False" ShowFilterButton="False" Width="30*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Nr_Omaggio, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Em." IsReadOnly="True" IsFilterable="False"  ShowFilterButton="False"  Width="35*">
                    <telerik:GridViewDataColumn.CellStyle>
                        <Style TargetType="telerik:GridViewCell">
                            <Setter Property="Foreground"  Value="Red" />
                        </Style>
                    </telerik:GridViewDataColumn.CellStyle>
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Consegnati, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn
					Header="Cnf."
					DataMemberBinding="{Binding Fl_Conferma, Mode=TwoWay}"
					IsFilterable="False" 
					ShowFilterButton="False"
					IsReadOnly="True"
					Width="35*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Fl_Conferma, FallbackValue=False}" IsEnabled="False" />
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                    <telerik:GridViewDataColumn.CellEditTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Fl_Conferma, FallbackValue=False, Mode=TwoWay}" IsThreeState="False" />
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellEditTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn UniqueName="visitatore"  Header="Visitatore" IsReadOnly="True" IsFilterable="True" ShowFilterButton="True" DataMemberBinding="{Binding Responsabile, FallbackValue=''}" Width="95*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Responsabile, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Ricevuta" IsReadOnly="True" IsFilterable="False"  ShowFilterButton="False" Width="80*">
                    <telerik:GridViewDataColumn.CellStyle>
                        <Style TargetType="telerik:GridViewCell">
                            <Setter Property="Foreground"  Value="Red" />
                        </Style>
                    </telerik:GridViewDataColumn.CellStyle>
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Ricevuta, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Importo" IsReadOnly="True" IsFilterable="False"  ShowFilterButton="False" Width="75*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Importo, FallbackValue=0, StringFormat=C, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Pag." IsReadOnly="True" IsFilterable="False"  ShowFilterButton="False" Width="33*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Simbolo, FallbackValue=''}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

                <telerik:GridViewDataColumn  Header="Dt. pagam." IsReadOnly="True" IsFilterable="False"  ShowFilterButton="False" Width="70*">
                    <telerik:GridViewDataColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Dt_Pagamento, FallbackValue='', StringFormat=d, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"></TextBlock>
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellTemplate>
                </telerik:GridViewDataColumn>

            </telerik:RadGridView.Columns>
            <telerik:RadContextMenu.ContextMenu>
                <telerik:RadContextMenu 
					x:Name="ContextMenu" 
					ItemClick="contextMenu_Click" 
					Opening="contextMenu_Opening">
                    <telerik:RadMenuItem Name="mnuPrint" Header="Stampa biglietti" CommandParameter="printtickets">
                        <telerik:RadMenuItem.IconTemplate>
                            <DataTemplate>
                                <Image Source="../Themes/Images/ButtonIcons/print_16.png" Stretch="UniformToFill"/>
                            </DataTemplate>
                        </telerik:RadMenuItem.IconTemplate>
                    </telerik:RadMenuItem>
                </telerik:RadContextMenu>
            </telerik:RadContextMenu.ContextMenu>
        </telerik:RadGridView>
    </Grid>
</my:BaseContentPage>