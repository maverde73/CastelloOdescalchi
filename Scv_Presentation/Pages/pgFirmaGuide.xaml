<my:BaseContentPage 
	x:Class="Presentation.Pages.pgFirmaGuide"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
	xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
	xmlns:sysglb="clr-namespace:System.Globalization;assembly=mscorlib"		    	
    mc:Ignorable="d" 
    d:DesignHeight="300" d:DesignWidth="800"
	xmlns:my="clr-namespace:Presentation"
	Title="Guide">

	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="40"></RowDefinition>
			<RowDefinition></RowDefinition>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Orientation="Horizontal">
			<telerik:RadDatePicker Name="dtpDate1" SelectedDate="{Binding VisitsDate, Mode=TwoWay}" Margin="5"></telerik:RadDatePicker>
		</StackPanel>
		<StackPanel Grid.Row="1">
			<telerik:RadGridView			
			Name="grdMaster" 
			AutoGenerateColumns="False" 
			VerticalAlignment="Top"
			HorizontalAlignment="Stretch"
			SelectionMode="Single"
			ItemsSource="{Binding}"	
			ScrollViewer.VerticalScrollBarVisibility="Auto"
			ScrollMode="RealTime"
			HeaderRowStyle="{StaticResource GridHeader}"	
			ShowGroupPanel="False"
			>
			<telerik:RadGridView.Columns>
				<telerik:GridViewDataColumn
					Header="Nominativo"
					DataMemberBinding="{Binding Nominativo}"
					MinWidth="200"
					/>

				<telerik:GridViewDataColumn
					Header="Orario"
					DataMemberBinding="{Binding Ora_Visita}"
					Width="70"
					/>

				<telerik:GridViewDataColumn
					Header="Lingua"
					DataMemberBinding="{Binding LinguaVisita}"
					Width="200"
					/>

				<telerik:GridViewDataColumn
					Header="Nota"
					DataMemberBinding="{Binding Nota}"
					Width="260"
					/>
			</telerik:RadGridView.Columns>
		</telerik:RadGridView>
		</StackPanel>
	</Grid>
	</my:BaseContentPage>