<my:BaseContentPage 
	x:Class="Presentation.Pages.pgSettingsPersonal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
	xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    mc:Ignorable="d" 
    d:DesignHeight="300" d:DesignWidth="800"
	xmlns:my="clr-namespace:Presentation"
	Title="Guide">

	<Grid Name="grd" Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"></RowDefinition>
			<RowDefinition Height="5"></RowDefinition>
			<RowDefinition Height="100*"></RowDefinition>
		</Grid.RowDefinitions>

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"></RowDefinition>
				<RowDefinition Height="5"></RowDefinition>
				<RowDefinition Height="100*"></RowDefinition>
			</Grid.RowDefinitions>

			<Border Name="brdGuide" Grid.Row="0" BorderBrush="Blue" BorderThickness="1" Background="#f1f1f1">
				<Grid x:Name="grdUsers" Margin="10" >
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"></RowDefinition>
						<RowDefinition Height="Auto"></RowDefinition>
						<RowDefinition Height="Auto"></RowDefinition>
						<RowDefinition Height="Auto"></RowDefinition>
						<RowDefinition Height="Auto"></RowDefinition>
					</Grid.RowDefinitions>
					<!-- Campi Utente-->
					<Grid Grid.Row="1" Margin="3">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="25*"></ColumnDefinition>
							<ColumnDefinition Width="25*"></ColumnDefinition>
							<ColumnDefinition Width="30*"></ColumnDefinition>
							<ColumnDefinition Width="25*"></ColumnDefinition>
							<ColumnDefinition Width="15*"></ColumnDefinition>
							<ColumnDefinition Width="15*"></ColumnDefinition>
						</Grid.ColumnDefinitions>
						<DockPanel Grid.Column="0" HorizontalAlignment="Stretch">
							<Label Content="Titolo" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
							<Label Name="txtTitolo" Validation.Error="Validation_Error" Style="{StaticResource DataLabel}" HorizontalAlignment="Stretch">
								<Binding
								Path="SelectedItem.Titolo"
								ValidatesOnDataErrors="True"
								NotifyOnValidationError="True"
								UpdateSourceTrigger="PropertyChanged"
								/>
							</Label>
						</DockPanel>
						<DockPanel Grid.Column="1" HorizontalAlignment="Stretch">
							<Label Content="Nominativo" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
							<Label Name="txtNominativo" Validation.Error="Validation_Error" Style="{StaticResource DataLabel}" HorizontalAlignment="Stretch">
								<Binding
								Path="SelectedItem.Nominativo"
								ValidatesOnDataErrors="True"
								NotifyOnValidationError="True"
								UpdateSourceTrigger="PropertyChanged"
								/>
							</Label>
						</DockPanel>
						<DockPanel HorizontalAlignment="Stretch" Grid.Column="2">
							<Label Content="Identificativo" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
							<Label Name="txtIdentificativo" Validation.Error="Validation_Error" Style="{StaticResource DataLabel}" HorizontalAlignment="Stretch">
								<Binding
								Path="SelectedItem.Identificativo"
								ValidatesOnDataErrors="True"
								NotifyOnValidationError="True"
								UpdateSourceTrigger="PropertyChanged"
								/>
							</Label>
						</DockPanel>
						<DockPanel HorizontalAlignment="Stretch" Grid.Column="3">
							<Label Content="Password" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
							<TextBox Name="txtPSW" Validation.Error="Validation_Error" MaxLength="50" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch">
								<Binding
								Path="SelectedItem.PSW"
							    Mode="TwoWay"
								ValidatesOnDataErrors="True"
								NotifyOnValidationError="True"
								UpdateSourceTrigger="PropertyChanged"
								/>
							</TextBox>
						</DockPanel>
						<DockPanel HorizontalAlignment="Stretch" Grid.Column="4">
							<Label Name="lblAttivo" Content="Attivo" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Center" DockPanel.Dock="Top" />
							<CheckBox Name="chkAttivo" IsThreeState="False" IsChecked="{Binding SelectedItem.Fl_Attivo, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" VerticalAlignment="Bottom" HorizontalAlignment="Center" IsEnabled="False" />
						</DockPanel>
						<DockPanel HorizontalAlignment="Stretch" Grid.Column="5">
							<Label Name="lblAmministratore" Content="Amministratore" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Center" DockPanel.Dock="Top" />
							<CheckBox Name="chkAmministratore" IsThreeState="False" IsChecked="{Binding SelectedItem.Fl_Amministratore, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" VerticalAlignment="Bottom" HorizontalAlignment="Center" IsEnabled="False" />
						</DockPanel>
					</Grid>
					<Grid Grid.Row="2" Margin="3">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="100*"></ColumnDefinition>
						</Grid.ColumnDefinitions>
						<StackPanel>
							<Label Content="Nota" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" />
							<TextBox 
								Name="txtNota" 
								Text="{Binding 
									Nota, Mode=TwoWay,  
									ValidatesOnDataErrors=True, 
									NotifyOnValidationError=True}" 
								MaxLength="100" 
								AcceptsReturn="True" 
								TextWrapping="Wrap" 
								Height="40" 
								MinHeight="40" 
								VerticalScrollBarVisibility="Auto" 
								Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch"
								/>
						</StackPanel>
					</Grid>
				</Grid>
			</Border>

			<Border Name="brdButtons" Grid.Row="2" BorderBrush="#ffffff" BorderThickness="0" Background="#ffffff">
				<Grid x:Name="grdButtons" Margin="3" >
					<StackPanel Orientation="Horizontal">
						<telerik:RadButton Name="btnSave" Content="Salva" Width="100" Height="25" />
						<telerik:RadButton Name="btnDelete" Content="Elimina" Width="100" Height="25" Visibility="Collapsed" />
					</StackPanel>
				</Grid>
			</Border>
		</Grid>
	</Grid>
</my:BaseContentPage>
