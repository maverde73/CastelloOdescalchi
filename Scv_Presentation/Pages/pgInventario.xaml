<my:BaseContentPage 
	x:Class="Presentation.Pages.pgInventario"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
	xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
	xmlns:sysglb="clr-namespace:System.Globalization;assembly=mscorlib"				
    mc:Ignorable="d" 
    d:DesignHeight="300" d:DesignWidth="800"
	xmlns:my="clr-namespace:Presentation"
	Title="Guide">
	<Grid Margin="10">
		<telerik:RadGridView			
				Name="grdMaster" 
				AutoGenerateColumns="False" 
				VerticalAlignment="Top"
				HorizontalAlignment="Stretch"
				SelectionMode="Single"
				ItemsSource="{Binding}"	
				ScrollViewer.VerticalScrollBarVisibility="Auto"
				ScrollMode="RealTime"
			>
			<telerik:RadGridView.Columns>
				<telerik:GridViewDataColumn 
					DataMemberBinding="{Binding TipoArticolo}"
					MinWidth="100"
					Width="140">
					<telerik:GridViewDataColumn.Header>
						<TextBlock Text="Tipo articolo" TextWrapping="Wrap" />
					</telerik:GridViewDataColumn.Header>
				</telerik:GridViewDataColumn>
				<telerik:GridViewDataColumn
					DataMemberBinding="{Binding Descrizione}"
					MinWidth="100"
					Width="200">
					<telerik:GridViewDataColumn.Header>
						<TextBlock Text="Descrizione" TextWrapping="Wrap" />
					</telerik:GridViewDataColumn.Header>
				</telerik:GridViewDataColumn>
				
				<telerik:GridViewDataColumn
					DataMemberBinding="{Binding ISBN}"
					Width="70">
					<telerik:GridViewDataColumn.Header>
						<TextBlock Text="ISBN" TextWrapping="Wrap" />
					</telerik:GridViewDataColumn.Header>
				</telerik:GridViewDataColumn>

				<telerik:GridViewDataColumn
					DataMemberBinding="{Binding Dt_UltimaEntrata, StringFormat=d, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"
					Width="80">
					<telerik:GridViewDataColumn.Header>
						<TextBlock Text="Dt. Ultima entrata" TextWrapping="Wrap" />
					</telerik:GridViewDataColumn.Header>
				</telerik:GridViewDataColumn>

				<telerik:GridViewDataColumn
					DataMemberBinding="{Binding CopieMagazzino}"
					Width="160">
					<telerik:GridViewDataColumn.Header>
						<TextBlock Text="Copie in magazzino" TextWrapping="Wrap" />
					</telerik:GridViewDataColumn.Header>
				</telerik:GridViewDataColumn>

				<telerik:GridViewDataColumn
					DataMemberBinding="{Binding CopieUfficio}"
					Width="80">
					<telerik:GridViewDataColumn.Header>
						<TextBlock Text="Copie in ufficio" TextWrapping="Wrap" />
					</telerik:GridViewDataColumn.Header>
				</telerik:GridViewDataColumn>

				<telerik:GridViewDataColumn
					DataMemberBinding="{Binding TotaleCopie}"
					Width="80">
					<telerik:GridViewDataColumn.Header>
						<TextBlock Text="Totale copie" TextWrapping="Wrap" />
					</telerik:GridViewDataColumn.Header>
				</telerik:GridViewDataColumn>
				<telerik:GridViewDataColumn
					Header="Prezzo acquisto"
					DataMemberBinding="{Binding PrezzoAcquisto, StringFormat=c, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"
					Width="80"
					/>

				<telerik:GridViewDataColumn
					DataMemberBinding="{Binding PrezzoVendita,  StringFormat=c, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"
					Width="80">
					<telerik:GridViewDataColumn.Header>
						<TextBlock Text="Prezzo vendita" TextWrapping="Wrap" />
					</telerik:GridViewDataColumn.Header>
				</telerik:GridViewDataColumn>
				
				<telerik:GridViewDataColumn
					DataMemberBinding="{Binding Anomalie}"
					Width="70">
					<telerik:GridViewDataColumn.Header>
						<TextBlock Text="Anomalie" TextWrapping="Wrap" />
					</telerik:GridViewDataColumn.Header>
				</telerik:GridViewDataColumn>
			</telerik:RadGridView.Columns>
		</telerik:RadGridView>
	</Grid>
</my:BaseContentPage>
