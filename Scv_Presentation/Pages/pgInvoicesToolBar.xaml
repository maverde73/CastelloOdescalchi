<my:BaseToolBarPage 
	x:Class="Presentation.Pages.pgInvoicesToolBar"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    mc:Ignorable="d" 
    d:DesignHeight="300" d:DesignWidth="300"
	xmlns:my="clr-namespace:Presentation"
	Title="Fatture">

	<Grid>
		<telerik:RadRibbonView
			Name="rib"
			Title="Prenotazioni"
			ApplicationName="Scv"
			VerticalAlignment="top"
			HorizontalAlignment="Stretch"
			TitleBarVisibility="Collapsed"
			>
			<telerik:RadRibbonTab Header="Home">
				<telerik:RadRibbonGroup Header="Fatture">
					<telerik:RadRibbonButton 
						Name="btnPrintAll" 
						Width="Auto"
						Height="55" 
						BorderThickness="0.3" 
						HorizontalContentAlignment="Left" 
						Padding="3"
						Margin="0,0,3,0"
						>
						<StackPanel Width="110" Height="55" Orientation="Vertical">
							<Image Width="16" Height="16" Source="/Themes/Images/ButtonIcons/print_16.png" Stretch="Fill"/>
							<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Stampa tutto" TextWrapping="Wrap"/>
						</StackPanel>
					</telerik:RadRibbonButton>
					<telerik:RadRibbonButton 
						Name="btnPrintSelected" 
						Width="Auto"
						Height="45" 
						BorderThickness="0.3" 
						HorizontalContentAlignment="Left" 
						Padding="3"
						Margin="0,0,3,0"
						>
						<StackPanel Width="110" Height="40" Orientation="Vertical">
							<Image Width="16" Height="16" Source="/Themes/Images/ButtonIcons/print_16.png" Stretch="Fill"/>
							<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Stampa selezionate" TextWrapping="Wrap"/>
						</StackPanel>
					</telerik:RadRibbonButton>
					<telerik:RadRibbonButton 
						Name="btnPrintSintesi" 
						Width="Auto"
						Height="55" 
						BorderThickness="0.3" 
						HorizontalContentAlignment="Left" 
						Padding="3"
						Margin="0,0,3,0"
						>
						<StackPanel Width="110" Height="55" Orientation="Vertical">
							<Image Width="16" Height="16" Source="/Themes/Images/ButtonIcons/print_16.png" Stretch="Fill"/>
							<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Stampa Sintesi Vendite Annuali" TextWrapping="Wrap"/>
						</StackPanel>
					</telerik:RadRibbonButton>
				</telerik:RadRibbonGroup>
			</telerik:RadRibbonTab>
		</telerik:RadRibbonView>
	</Grid>
</my:BaseToolBarPage>
