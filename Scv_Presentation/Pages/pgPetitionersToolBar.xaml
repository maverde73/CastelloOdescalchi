<my:BaseToolBarPage 
	  xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
	  x:Class="Presentation.Pages.pgPetitionersToolBar"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="292" d:DesignWidth="590"
	  xmlns:my="clr-namespace:Presentation"
	 Title="pgPetitionersToolBar">		
	
    <Grid>
		<telerik:RadRibbonView
			Name="rib"
			Title="Richiedenti"
			ApplicationName="Scv"
			VerticalAlignment="top"
			HorizontalAlignment="Stretch"
			>			
			<telerik:RadRibbonTab Header="Home">
				<telerik:RadRibbonGroup Header="Schede Richiedenti">
						<telerik:RadRibbonButton 
							Name="btnNew" 
							Width="Auto"
							Height="45" 
							BorderThickness="0.3" 
							HorizontalContentAlignment="Center" 
							Padding="3" 
							Margin="3,0,0,0"
							>
						<StackPanel Width="50" Height="40" Orientation="Vertical">
							<Image Width="16" Height="16" Source="/Themes/Images/ButtonIcons/newTableItem_16.png" Stretch="Fill"/>
							<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Nuovo" TextWrapping="Wrap"/>
						</StackPanel>
					</telerik:RadRibbonButton>
					<telerik:RadRibbonButton 
						Name="btnOpen" 
						Width="Auto"
						Height="45" 
						BorderThickness="0.3" 
						HorizontalContentAlignment="Left" 
						Padding="3" 
						Margin="0"
						>
						<StackPanel Width="50" Height="40" Orientation="Vertical">
							<Image  Width="16" Height="16" Source="/Themes/Images/ButtonIcons/OpenItem_16.png" Stretch="Fill"/>
							<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Apri" TextWrapping="Wrap"/>
						</StackPanel>
					</telerik:RadRibbonButton>
					<telerik:RadRibbonButton 
						Name="btnDelete" 
						Width="Auto"
						Height="45" 
						BorderThickness="0.3" 
						HorizontalContentAlignment="Left" 
						Padding="3"
						Margin="0,0,3,0"
						>
						<StackPanel Width="50" Height="40" Orientation="Vertical">
							<Image Width="16" Height="16" Source="/Themes/Images/ButtonIcons/DeleteItem_16.png" Stretch="Fill"/>
							<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Elimina" TextWrapping="Wrap"/>
						</StackPanel>
					</telerik:RadRibbonButton>
				</telerik:RadRibbonGroup>
			</telerik:RadRibbonTab>
		</telerik:RadRibbonView>						
	</Grid>
</my:BaseToolBarPage>
