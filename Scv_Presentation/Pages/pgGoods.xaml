<my:BaseContentPage 
	x:Class="Presentation.Pages.pgGoods"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
	xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
	xmlns:sysglb="clr-namespace:System.Globalization;assembly=mscorlib"				
    mc:Ignorable="d" 
    d:DesignHeight="300" d:DesignWidth="800"
	xmlns:my="clr-namespace:Presentation"
	Title="Guide">

	<Grid Margin="10">
		<telerik:RadGridView			
				Name="grdMaster" 
				AutoGenerateColumns="False" 
				VerticalAlignment="Top"
				HorizontalAlignment="Stretch"
				SelectionMode="Single"
				ItemsSource="{Binding}"	
				ScrollViewer.VerticalScrollBarVisibility="Auto"
				ScrollMode="RealTime"
			>
			<telerik:RadGridView.Columns>
				<telerik:GridViewDataColumn 
					Header="Tipo articolo"
					DataMemberBinding="{Binding TipoArticolo}"
					MinWidth="100"
					Width="140"
					/>

				<telerik:GridViewDataColumn
					Header="Descrizione"
					DataMemberBinding="{Binding Descrizione}"
					MinWidth="100"
					Width="200"
					/>

				<telerik:GridViewDataColumn
					Header="ISBN"
					DataMemberBinding="{Binding ISBN}"
					Width="70"
					/>

				<telerik:GridViewDataColumn
					Header="Codice"
					DataMemberBinding="{Binding Codice}"
					MinWidth="70"
					Width="70"
					/>

				<telerik:GridViewDataColumn
					Header="Autore"
					DataMemberBinding="{Binding Autore}"
					MinWidth="150"
					Width="150"
					/>

				<telerik:GridViewDataColumn
					Header="Editrice"
					DataMemberBinding="{Binding Editrice}"
					MinWidth="100"
					Width="160"
					/>

				<telerik:GridViewDataColumn
					Header="Prezzo acquisto"
					DataMemberBinding="{Binding PrezzoAcquisto, StringFormat=c, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"
					Width="110"
					/>

				<telerik:GridViewDataColumn
					Header="Prezzo vendita"
					DataMemberBinding="{Binding PrezzoVendita,  StringFormat=c, ConverterCulture={x:Static sysglb:CultureInfo.CurrentUICulture}}"
					MinWidth="80"
					Width="110"
					/>

			</telerik:RadGridView.Columns>

			<telerik:RadContextMenu.ContextMenu>
				<telerik:RadContextMenu 
					x:Name="ContextMenu" 
					ItemClick="contextMenu_Click" 
					Opening="contextMenu_Opening">
					<telerik:RadMenuItem Name="mnuOpen" Header="Apri" CommandParameter="open">
						<telerik:RadMenuItem.IconTemplate>
							<DataTemplate>
								<Image Source="../Themes/Images/ButtonIcons/OpenItem_16.png" Stretch="UniformToFill"/>
							</DataTemplate>
						</telerik:RadMenuItem.IconTemplate>
					</telerik:RadMenuItem>
					<telerik:RadMenuItem Name="mnuDelete" Header="Elimina" CommandParameter="delete" >
						<telerik:RadMenuItem.IconTemplate>
							<DataTemplate>
								<Image Source="../Themes/Images/ButtonIcons/DeleteItem_16.png" Stretch="UniformToFill"/>
							</DataTemplate>
						</telerik:RadMenuItem.IconTemplate>
					</telerik:RadMenuItem>
				</telerik:RadContextMenu>
			</telerik:RadContextMenu.ContextMenu>
		</telerik:RadGridView>
	</Grid>
</my:BaseContentPage>
