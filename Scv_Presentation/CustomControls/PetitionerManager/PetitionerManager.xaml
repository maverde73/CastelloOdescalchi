<my:BaseControl 
	x:Class="Presentation.PetitionerManager"
	xmlns:my="clr-namespace:Presentation"  
	xmlns:telerik="clr-namespace:Telerik.Windows.Controls;assembly=Telerik.Windows.Controls.Input"
	xmlns:telerik2="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    mc:Ignorable="d" 
    d:DesignHeight="300" 
	d:DesignWidth="1000">

	<UserControl.Resources>
		<SolidColorBrush x:Key="Black" Color="#FF000000"/>
		<SolidColorBrush x:Key="Grey" Color="#FF767676"/>
		<SolidColorBrush x:Key="W Grey" Color="#FFD6D4D4"/>
		<Style x:Key="AutoCompleteStyle" TargetType="TextBlock">
			<Setter Property="FontFamily" Value="Segoe UI" />
			<Setter Property="FontSize" Value="13.333" />
			<Setter Property="Foreground" Value="#FF0A0A0A" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>

		<Style x:Key="ColumnHeaderStyle" TargetType="TextBlock">
			<Setter Property="FontFamily" Value="Segoe UI" />
			<Setter Property="FontSize" Value="16" />
			<Setter Property="Foreground" Value="#FFFFFFFF" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>

		<Style x:Key="PathFrameEllipseStyle" TargetType="Ellipse">
			<Setter Property="Width" Value="40" />
			<Setter Property="Height" Value="40" />
			<Setter Property="Stroke" Value="#FFFFFFFF" />
			<Setter Property="StrokeThickness" Value="2" />
		</Style>

		<DataTemplate x:Name="tmpPetitioner" x:Key="aucPetitioner">
			<StackPanel Orientation="Horizontal">
				<TextBlock Text="{Binding Cognome}" Style="{StaticResource AutoCompleteStyle}" />
				<TextBlock Text=", " Style="{StaticResource AutoCompleteStyle}" />
				<TextBlock Text="{Binding Nome}" Style="{StaticResource AutoCompleteStyle}" />
			</StackPanel>
		</DataTemplate>
	</UserControl.Resources>

	<Grid VerticalAlignment="Stretch">
		<StackPanel>
			<StackPanel Name="pnlSearch" Orientation="Horizontal" Margin="5">
				<DockPanel Margin="0,5,0,0">
					<Label Name="lblSearch" Content="Cerca Richiedente" Style="{StaticResource CaptionLabel}" DockPanel.Dock="Top" />
					<telerik2:RadAutoCompleteBox 
						Name="cmb"
						HorizontalAlignment="Stretch"
						MinWidth="250"
						SelectionMode="Single"
						TextSearchMode="Contains"
						TextSearchPath="SearchField"
						DropDownItemTemplate="{StaticResource aucPetitioner}"	
						DisplayMemberPath="Cognome"
						WatermarkContent="Richiedente..."
						AutoCompleteMode="Suggest"
						ItemsSource="{Binding Availables, Mode=TwoWay}"
						SelectedItem="{Binding AutoCompleteBoxSelectedItem, Mode=TwoWay}"
						SelectionChanged="cmb_SelectionChanged"
						SearchTextChanged="cmb_SearchTextChanged"	
						BorderBrush="#FF25A0DA" 
						BorderThickness="1"
						Style="{StaticResource DataRadTextBox}"
						VerticalContentAlignment="Bottom"
					/>
				</DockPanel>
			</StackPanel>
			<StackPanel Name="pnlEdit" Visibility="Visible" DataContext="{Binding SelectedItem}" Margin="5">
				<StackPanel Orientation="Horizontal" Margin="0,5,0,0">
					<DockPanel MinWidth="250">
						<Label Content="Cognome" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtCognome" Text="{Binding Cognome, Mode=TwoWay}" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel MinWidth="250">
						<Label Content="Nome" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtNome" Text="{Binding Nome, Mode=TwoWay}" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel>
						<my:TitleManager x:Name="tmn" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel MinWidth="100">
						<my:LanguageManager x:Name="lmn" Caption="Lingua abituale" />
					</DockPanel>
				</StackPanel>
				<StackPanel Orientation="Horizontal" Margin="0,5,0,0">
					<DockPanel>
						<Label Content="Email" Grid.Column="9" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtEmail" Text="{Binding Email, Mode=TwoWay}" MinWidth="250" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel>
						<Label Content="Tel. Casa" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtTelefonoCasa" Text="{Binding Tel_Casa, Mode=TwoWay}" MinWidth="140" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel>
						<Label Content="Tel. Ufficio" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtTelUfficio" Text="{Binding Tel_Ufficio, Mode=TwoWay}" MinWidth="140" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel>
						<Label Content="Tel. Cell." Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtTelCellulare" Text="{Binding Tel_Cellulare, Mode=TwoWay}" MinWidth="140" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel Margin="0">
						<my:OrganizationManager x:Name="omn" HorizontalAlignment="Stretch" />
					</DockPanel>
				</StackPanel>
				<StackPanel Orientation="Horizontal" Margin="0,5,0,0">
					<DockPanel>
						<my:LocationManager	x:Name="lcm" HorizontalAlignment="Stretch" />
					</DockPanel>
					<DockPanel>
						<Label Content="Indirizzo" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" DockPanel.Dock="Top" />
						<TextBox Name="txtIndirizzo" Text="{Binding Indirizzo, Mode=TwoWay}" MinWidth="285" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
					</DockPanel>
				</StackPanel>
				<StackPanel Margin="0,5,0,0">
					<Label Content="Nota" Style="{StaticResource CaptionLabel}" HorizontalAlignment="Stretch" />
					<TextBox Name="txtNota" Text="{Binding Nota, Mode=TwoWay}" MinWidth="690" Style="{StaticResource DataTextBox}" HorizontalAlignment="Stretch" />
				</StackPanel>
			</StackPanel>			
		</StackPanel>
	</Grid>
</my:BaseControl>
